    <!-- ======================== SCRIPTS ======================== -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // ---- Navbar scroll behaviour ----
        const nav = document.getElementById('edgeNav');
        window.addEventListener('scroll', () => {
            nav.classList.toggle('scrolled', window.scrollY > 40);
        }, { passive: true });
        // Init on load
        if (window.scrollY > 40) nav.classList.add('scrolled');

        // ---- Mobile menu toggle ----
        const toggle = document.getElementById('navToggle');
        const mobileMenu = document.getElementById('navMobile');
        toggle.addEventListener('click', () => {
            const isOpen = mobileMenu.classList.toggle('open');
            toggle.classList.toggle('open', isOpen);
            document.body.style.overflow = isOpen ? 'hidden' : '';
        });

        // Close on link click
        mobileMenu.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', () => {
                mobileMenu.classList.remove('open');
                toggle.classList.remove('open');
                document.body.style.overflow = '';
            });
        });

        // Close on outside click
        document.addEventListener('click', (e) => {
            if (!nav.contains(e.target) && !mobileMenu.contains(e.target)) {
                mobileMenu.classList.remove('open');
                toggle.classList.remove('open');
                document.body.style.overflow = '';
            }
        });

        // ---- Active link highlight ----
        const path = window.location.pathname.toLowerCase();
        document.querySelectorAll('.nav-links li a, .nav-mobile-links li a').forEach(link => {
            const href = link.getAttribute('href');
            if (!href) return;
            const hPath = new URL(href, window.location.origin).pathname.toLowerCase();
            if (path === hPath || (hPath !== '/' && path.startsWith(hPath))) {
                link.classList.add('active-link');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
