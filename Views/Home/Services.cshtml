@{
    ViewData["Title"] = "Services";
}

<style>
    :root {
        --navy-deep: #060F1E;
        --navy-main: #0B1D35;
        --blue-primary: #1A4A8A;
        --blue-soft: #2563B0;
        --blue-glow: #3B82F6;
        --gold-accent: #C9A84C;
        --gold-light: #E8C96A;
        --text-white: #FFFFFF;
        --text-muted: rgba(255,255,255,0.72);
        --text-subtle: rgba(255,255,255,0.42);
        --glass-bg: rgba(6,15,30,0.55);
        --glass-border: rgba(255,255,255,0.08);
        --glass-border-hover: rgba(255,255,255,0.18);
    }

    *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        background: var(--navy-deep);
        color: var(--text-white);
        overflow-x: hidden;
        font-family: 'Segoe UI', 'Helvetica Neue', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
    }
    html, body {
    max-width: 100%;
    overflow-x: hidden;
}

    /* ===================== ANIMATIONS ===================== */
    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(32px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeDown {
        from {
            opacity: 0;
            transform: translateY(-24px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes shimmerLine {
        0% {
            transform: translateX(-100%);
        }

        100% {
            transform: translateX(200%);
        }
    }

    @@keyframes gradientShift {
        0%, 100% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }
    }

    @@keyframes dotPulse {
        0%, 100% {
            opacity: 1;
            transform: scale(1);
        }

        50% {
            opacity: 0.5;
            transform: scale(0.7);
        }
    }

    @@keyframes scanLine {
        0% {
            top: -4px;
        }

        100% {
            top: 100%;
        }
    }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-12px);
        }
    }

    @@keyframes scaleIn {
        from {
            opacity: 0;
            transform: scale(0.96);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    @@keyframes cardReveal {
        from {
            opacity: 0;
            transform: translateY(40px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ===================== HERO ===================== */
    .services-hero {
        min-height: 72vh;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 160px 7% 120px;
        overflow: hidden;
        isolation: isolate;
        text-align: center;
    }

    .hero-video-bg {
        position: absolute;
        inset: 0;
        z-index: -3;
        overflow: hidden;
    }

        .hero-video-bg video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.18;
            filter: brightness(0.5) saturate(0.6) hue-rotate(195deg);
        }

    .hero-overlay-base {
        position: absolute;
        inset: 0;
        z-index: -2;
        background: linear-gradient(160deg, rgba(6,15,30,0.92) 0%, rgba(11,29,53,0.78) 50%, rgba(6,15,30,0.95) 100% );
    }

    .hero-overlay-radial {
        position: absolute;
        inset: 0;
        z-index: -1;
        background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(37,99,176,0.14) 0%, transparent 70%), radial-gradient(ellipse 40% 30% at 80% 20%, rgba(201,168,76,0.07) 0%, transparent 60%);
    }

    /* Grid overlay */
    .services-hero::after {
        content: "";
        position: absolute;
        inset: 0;
        background-image: linear-gradient(rgba(255,255,255,0.022) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.022) 1px, transparent 1px);
        background-size: 80px 80px;
        z-index: -1;
        pointer-events: none;
    }

    /* Scan line */
    .hero-scanline {
        position: absolute;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg, transparent, rgba(59,130,246,0.2), transparent);
        z-index: 0;
        animation: scanLine 9s linear infinite;
        pointer-events: none;
    }

    .hero-inner {
        position: relative;
        z-index: 1;
        max-width: 820px;
        margin: 0 auto;
        animation: fadeIn 1.2s ease-out;
    }

    .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 7px 20px;
        background: rgba(201,168,76,0.08);
        border: 1px solid rgba(201,168,76,0.22);
        border-radius: 100px;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--gold-light);
        margin-bottom: 28px;
        animation: fadeDown 0.9s ease-out 0.2s backwards;
        position: relative;
        overflow: hidden;
    }

        .hero-eyebrow::after {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 40%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.12), transparent);
            animation: shimmerLine 3.5s ease-in-out infinite;
        }

    .eyebrow-dot {
        width: 5px;
        height: 5px;
        background: var(--gold-accent);
        border-radius: 50%;
        animation: dotPulse 2s ease-in-out infinite;
    }

    .services-hero h1 {
        font-size: clamp(2.8rem, 5.5vw, 4.6rem);
        font-weight: 300;
        line-height: 1.12;
        letter-spacing: -0.03em;
        margin-bottom: 24px;
        animation: fadeDown 0.9s ease-out 0.35s backwards;
    }

        .services-hero h1 strong {
            font-weight: 800;
            display: block;
            background: linear-gradient(120deg, #FFFFFF 0%, #A8CBFF 50%, #FFFFFF 100%);
            background-size: 200% 200%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: gradientShift 6s ease infinite 1s;
        }

    .hero-divider {
        width: 56px;
        height: 2px;
        background: linear-gradient(90deg, var(--gold-accent), transparent);
        margin: 28px auto;
        animation: fadeIn 0.9s ease-out 0.5s backwards;
    }

    .services-hero p {
        font-size: clamp(1rem, 1.8vw, 1.18rem);
        color: var(--text-muted);
        line-height: 1.78;
        max-width: 680px;
        margin: 0 auto;
        animation: fadeDown 0.9s ease-out 0.55s backwards;
    }

    /* Scroll indicator */
    .hero-scroll {
        position: absolute;
        bottom: 40px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        z-index: 1;
        animation: fadeIn 1.2s ease-out 1s backwards;
    }

        .hero-scroll span {
            font-size: 0.65rem;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--text-subtle);
            font-weight: 600;
        }

    .scroll-line {
        width: 1px;
        height: 48px;
        background: linear-gradient(180deg, var(--gold-accent), transparent);
        animation: float 2s ease-in-out infinite;
    }

    /* ===================== SECTION LABEL ===================== */
    .section-label {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 3px;
        color: var(--gold-accent);
        margin-bottom: 20px;
    }

        .section-label::before {
            content: "";
            width: 24px;
            height: 1px;
            background: var(--gold-accent);
        }

    /* ===================== SERVICES GRID ===================== */
    .services-section {
        padding: 120px 7% 100px;
        position: relative;
        background: linear-gradient(180deg, var(--navy-deep) 0%, #091829 60%, var(--navy-deep) 100%);
    }

        .services-section::before {
            content: "";
            position: absolute;
            inset: 0;
            background-image: radial-gradient(rgba(59,130,246,0.035) 1px, transparent 1px);
            background-size: 40px 40px;
            pointer-events: none;
        }

    .services-section-header {
        text-align: center;
        max-width: 700px;
        margin: 0 auto 72px;
    }

        .services-section-header h2 {
            font-size: clamp(2.2rem, 4vw, 3.2rem);
            font-weight: 300;
            letter-spacing: -0.025em;
            line-height: 1.2;
            margin-bottom: 18px;
        }

            .services-section-header h2 strong {
                font-weight: 800;
            }

        .services-section-header p {
            font-size: clamp(1rem, 1.6vw, 1.1rem);
            color: var(--text-muted);
            line-height: 1.75;
        }

    .services-grid {
        max-width: 1380px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 28px;
    }

    /* ===================== SERVICE CARD ===================== */
    .service-card {
        background: rgba(11,29,53,0.6);
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 20px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        position: relative;
        transition: all 0.5s cubic-bezier(0.4,0,0.2,1);
        animation: cardReveal 0.7s ease-out backwards;
        backdrop-filter: blur(8px);
    }

        .service-card:nth-child(1) {
            animation-delay: 0.05s;
        }

        .service-card:nth-child(2) {
            animation-delay: 0.1s;
        }

        .service-card:nth-child(3) {
            animation-delay: 0.15s;
        }

        .service-card:nth-child(4) {
            animation-delay: 0.2s;
        }

        .service-card:nth-child(5) {
            animation-delay: 0.25s;
        }

        .service-card:nth-child(6) {
            animation-delay: 0.3s;
        }

        .service-card:nth-child(7) {
            animation-delay: 0.35s;
        }

        /* Gold top bar on hover */
        .service-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--gold-accent), var(--gold-light), var(--gold-accent));
            background-size: 200% 100%;
            opacity: 0;
            transition: opacity 0.4s ease;
            animation: shimmerLine 3s linear infinite;
            z-index: 3;
        }

        .service-card::after {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 50% 100%, rgba(37,99,176,0.1) 0%, transparent 70%);
            opacity: 0;
            transition: opacity 0.5s ease;
            pointer-events: none;
            z-index: 0;
        }

        .service-card:hover {
            transform: translateY(-10px);
            border-color: rgba(255,255,255,0.14);
            box-shadow: 0 28px 70px rgba(0,0,0,0.45), 0 0 40px rgba(37,99,176,0.12);
            background: rgba(11,29,53,0.85);
        }

            .service-card:hover::before {
                opacity: 1;
            }

            .service-card:hover::after {
                opacity: 1;
            }

    /* Image */
    .card-image {
        position: relative;
        overflow: hidden;
        height: 220px;
        flex-shrink: 0;
    }

        .card-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.7s cubic-bezier(0.4,0,0.2,1), filter 0.5s ease;
            filter: brightness(0.75) saturate(0.85);
        }

    .service-card:hover .card-image img {
        transform: scale(1.08);
        filter: brightness(0.9) saturate(1);
    }

    .card-image::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, transparent 30%, rgba(6,15,30,0.8) 100%);
        z-index: 1;
    }

    /* Gold corner accent */
    .card-image::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 60px;
        height: 60px;
        border-top: 2px solid var(--gold-accent);
        border-left: 2px solid var(--gold-accent);
        border-radius: 20px 0 0 0;
        z-index: 2;
        opacity: 0.5;
        transition: opacity 0.3s, width 0.3s, height 0.3s;
    }

    .service-card:hover .card-image::before {
        opacity: 1;
        width: 70px;
        height: 70px;
    }

    /* Body */
    .card-body {
        padding: 30px 32px 36px;
        flex: 1;
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
    }

    .card-num {
        font-size: 0.62rem;
        font-weight: 800;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--gold-accent);
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .card-num::before {
            content: "";
            width: 18px;
            height: 1px;
            background: var(--gold-accent);
        }

    .card-body h3 {
        font-size: clamp(1.1rem, 1.8vw, 1.3rem);
        font-weight: 700;
        line-height: 1.3;
        letter-spacing: -0.01em;
        margin-bottom: 20px;
        color: #fff;
        transition: color 0.3s;
        position: relative;
        padding-bottom: 16px;
    }

        .card-body h3::after {
            content: "";
            position: absolute;
            bottom: 0;
            left: 0;
            width: 32px;
            height: 1px;
            background: var(--gold-accent);
            transition: width 0.4s ease;
        }

    .service-card:hover .card-body h3 {
        color: var(--gold-light);
    }

        .service-card:hover .card-body h3::after {
            width: 100%;
        }

    .card-body ul {
        list-style: none;
        padding: 0;
        margin: 0 0 24px;
        display: grid;
        gap: 10px;
        flex: 1;
    }

        .card-body ul li {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            font-size: 0.93rem;
            color: var(--text-muted);
            line-height: 1.6;
            transition: color 0.25s, transform 0.25s;
        }

            .card-body ul li:hover {
                color: #fff;
                transform: translateX(4px);
            }

            .card-body ul li::before {
                content: "";
                flex-shrink: 0;
                width: 18px;
                height: 18px;
                border-radius: 50%;
                background: rgba(201,168,76,0.1);
                border: 1px solid rgba(201,168,76,0.3);
                margin-top: 1px;
                transition: background 0.3s, border-color 0.3s;
                display: flex;
                align-items: center;
                justify-content: center;
                position: relative;
            }

    .service-card:hover .card-body ul li::before {
        background: rgba(201,168,76,0.18);
        border-color: rgba(201,168,76,0.6);
    }

    .card-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--gold-light);
        font-size: 0.8rem;
        font-weight: 700;
        text-decoration: none;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        padding-bottom: 3px;
        border-bottom: 1px solid rgba(201,168,76,0.25);
        transition: gap 0.25s, color 0.25s, border-color 0.25s;
        margin-top: auto;
    }

        .card-link:hover {
            gap: 14px;
            color: #fff;
            border-color: rgba(255,255,255,0.5);
        }

        .card-link svg {
            width: 14px;
            height: 14px;
            transition: transform 0.25s;
        }

        .card-link:hover svg {
            transform: translateX(4px);
        }

    /* ===================== VISION ===================== */
    .vision {
        padding: 120px 7%;
        background: linear-gradient(160deg, #050D1A 0%, #0B1D35 50%, #050D1A 100%);
        border-top: 1px solid rgba(255,255,255,0.05);
        border-bottom: 1px solid rgba(255,255,255,0.05);
        position: relative;
        overflow: hidden;
        text-align: center;
    }

        .vision::before {
            content: "";
            position: absolute;
            width: 600px;
            height: 600px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(59,130,246,0.06) 0%, transparent 70%);
            top: 50%;
            left: 50%;
            transform: translate(-50%,-50%);
            pointer-events: none;
        }

    .vision-quote {
        position: relative;
        max-width: 900px;
        margin: 0 auto;
    }

    .vision-mark {
        font-size: 7rem;
        line-height: 0.6;
        font-family: Georgia, serif;
        color: rgba(201,168,76,0.15);
        display: block;
        margin-bottom: 24px;
        user-select: none;
    }

    .vision-text {
        font-size: clamp(1.4rem, 3vw, 2.2rem);
        font-weight: 300;
        line-height: 1.68;
        letter-spacing: -0.01em;
        color: rgba(255,255,255,0.9);
    }

        .vision-text strong {
            font-weight: 700;
            color: #fff;
        }

    /* ===================== CTA ===================== */
    .cta-section {
        padding: 130px 7%;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .cta-section::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(160deg, rgba(26,74,138,0.9) 0%, rgba(37,99,176,0.85) 50%, rgba(11,29,53,0.95) 100% );
            z-index: -1;
        }

        .cta-section::after {
            content: "";
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
            background-size: 60px 60px;
            z-index: -1;
            pointer-events: none;
        }

        .cta-section h2 {
            font-size: clamp(2.3rem, 4.2vw, 3.4rem);
            font-weight: 300;
            letter-spacing: -0.025em;
            margin-bottom: 20px;
            animation: fadeDown 0.8s ease-out;
        }

            .cta-section h2 strong {
                font-weight: 800;
            }

        .cta-section p {
            max-width: 560px;
            margin: 0 auto 48px;
            color: var(--text-muted);
            font-size: clamp(1rem, 1.7vw, 1.12rem);
            line-height: 1.75;
            animation: fadeUp 0.8s ease-out 0.2s backwards;
        }

    .cta-actions {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
        animation: fadeUp 0.8s ease-out 0.35s backwards;
    }

    /* Shared buttons */
    .btn-primary {
        position: relative;
        background: linear-gradient(135deg, var(--blue-primary), var(--blue-soft));
        color: #fff;
        padding: 15px 38px;
        border-radius: 8px;
        font-weight: 700;
        font-size: 0.95rem;
        letter-spacing: 0.03em;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
        box-shadow: 0 4px 24px rgba(26,74,138,0.35), inset 0 1px 0 rgba(255,255,255,0.1);
        overflow: hidden;
    }

        .btn-primary::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255,255,255,0.12), transparent);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 40px rgba(26,74,138,0.5);
        }

            .btn-primary:hover::before {
                opacity: 1;
            }

    .btn-secondary {
        border: 1.5px solid rgba(255,255,255,0.2);
        color: var(--text-white);
        padding: 15px 38px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.95rem;
        letter-spacing: 0.03em;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
        backdrop-filter: blur(8px);
        background: rgba(255,255,255,0.04);
    }

        .btn-secondary:hover {
            border-color: rgba(255,255,255,0.45);
            background: rgba(255,255,255,0.08);
            transform: translateY(-3px);
        }

    /* ===================== RESPONSIVE ===================== */
    @@media (max-width: 1200px) {
        .services-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 24px;
        }
    }

    @@media (max-width: 992px) {
        .services-hero {
            padding: 140px 6% 100px;
        }

        .services-section {
            padding: 100px 6% 80px;
        }
    }

    @@media (max-width: 768px) {
        .services-hero {
            padding: 120px 5% 80px;
            min-height: 60vh;
        }

        .services-section {
            padding: 80px 5%;
        }

        .services-grid {
            grid-template-columns: 1fr;
            gap: 20px;
        }

        .vision {
            padding: 90px 5%;
        }

        .cta-section {
            padding: 90px 5%;
        }

        .hero-scroll {
            display: none;
        }
    }

    @@media (max-width: 576px) {
        .services-hero {
            padding: 100px 4% 70px;
        }

        .services-section {
            padding: 70px 4%;
        }

        .card-image {
            height: 180px;
        }

        .card-body {
            padding: 24px 24px 28px;
        }

        .cta-section {
            padding: 80px 4%;
        }

        .cta-actions {
            flex-direction: column;
            align-items: center;
        }

            .cta-actions .btn-primary,
            .cta-actions .btn-secondary {
                width: 100%;
                max-width: 300px;
                justify-content: center;
            }
    }
</style>

<!-- ======================== HERO ======================== -->
<section class="services-hero">
    <div class="hero-video-bg">
        <video autoplay muted loop playsinline preload="auto">
            <source src="~/Videos/data_analysis_digital.mov" type="video/mp4" />
        </video>
    </div>
    <div class="hero-overlay-base"></div>
    <div class="hero-overlay-radial"></div>
    <div class="hero-scanline"></div>

    <div class="hero-inner">
        <div class="hero-eyebrow">
            <span class="eyebrow-dot"></span>
            Our Expertise
        </div>
        <h1>
