        overflow: hidden;
    }

        .btn-primary::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg,rgba(255,255,255,.12),transparent);
            opacity: 0;
            transition: opacity .3s;
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 40px rgba(26,74,138,.5);
        }

            .btn-primary:hover::before {
