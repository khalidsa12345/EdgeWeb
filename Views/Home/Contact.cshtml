@{
    ViewData["Title"] = "Contact Us";
}

<style>
    :root {
        --navy-deep: #060F1E;
        --navy-main: #0B1D35;
        --blue-primary: #1A4A8A;
        --blue-soft: #2563B0;
        --blue-glow: #3B82F6;
        --gold-accent: #C9A84C;
        --gold-light: #E8C96A;
        --text-white: #FFFFFF;
        --text-muted: rgba(255,255,255,0.72);
        --text-subtle: rgba(255,255,255,0.42);
        --glass-bg: rgba(11,29,53,0.65);
        --glass-border: rgba(255,255,255,0.09);
    }

    *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        background: var(--navy-deep);
        color: var(--text-white);
        overflow-x: hidden;
        font-family: 'Segoe UI', 'Helvetica Neue', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
    }

    html, body {
        max-width: 100%;
        overflow-x: hidden;
    }

    /* ===================== ANIMATIONS ===================== */
    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(32px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeDown {
        from {
            opacity: 0;
            transform: translateY(-24px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes fadeLeft {
        from {
            opacity: 0;
            transform: translateX(-36px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes fadeRight {
        from {
            opacity: 0;
            transform: translateX(36px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes shimmerLine {
        0% {
            transform: translateX(-100%);
        }

        100% {
            transform: translateX(200%);
        }
    }

    @@keyframes gradientShift {
        0%, 100% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }
    }

    @@keyframes dotPulse {
        0%, 100% {
            opacity: 1;
            transform: scale(1);
        }

        50% {
            opacity: 0.5;
            transform: scale(0.7);
        }
    }

    @@keyframes scanLine {
        0% {
            top: -4px;
        }

        100% {
            top: 100%;
        }
    }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-12px);
        }
    }

    @@keyframes lineGrow {
        from {
            width: 0;
        }

        to {
            width: 56px;
        }
    }

    @@keyframes cardReveal {
        from {
            opacity: 0;
            transform: translateY(28px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes iconPulse {
        0%, 100% {
            box-shadow: 0 0 0 0 rgba(201,168,76,0);
        }

        50% {
            box-shadow: 0 0 0 10px rgba(201,168,76,0.08);
        }
    }

    /* ===================== HERO ===================== */
    .contact-hero {
        min-height: 65vh;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 170px 7% 130px;
        overflow: hidden;
        isolation: isolate;
        text-align: center;
    }

    .hero-video-bg {
        position: absolute;
        inset: 0;
        z-index: -3;
        overflow: hidden;
    }

        .hero-video-bg video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.2;
            filter: brightness(0.5) saturate(0.6) hue-rotate(200deg);
        }

    .hero-overlay-base {
        position: absolute;
        inset: 0;
        z-index: -2;
        background: linear-gradient(160deg,rgba(6,15,30,0.92) 0%,rgba(11,29,53,0.78) 50%,rgba(6,15,30,0.96) 100%);
    }

    .hero-overlay-radial {
        position: absolute;
        inset: 0;
        z-index: -1;
        background: radial-gradient(ellipse 70% 60% at 50% 50%,rgba(37,99,176,0.14) 0%,transparent 70%), radial-gradient(ellipse 35% 25% at 75% 20%,rgba(201,168,76,0.07) 0%,transparent 60%);
    }

    .contact-hero::after {
        content: "";
        position: absolute;
        inset: 0;
        background-image: linear-gradient(rgba(255,255,255,0.022) 1px,transparent 1px), linear-gradient(90deg,rgba(255,255,255,0.022) 1px,transparent 1px);
        background-size: 80px 80px;
        z-index: -1;
        pointer-events: none;
    }

    .hero-scanline {
        position: absolute;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg,transparent,rgba(59,130,246,0.22),transparent);
        z-index: 0;
        animation: scanLine 10s linear infinite;
        pointer-events: none;
    }

    .hero-inner {
        position: relative;
        z-index: 1;
        max-width: 760px;
        margin: 0 auto;
        animation: fadeIn 1.2s ease-out;
    }

    .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 7px 20px;
        background: rgba(201,168,76,0.08);
        border: 1px solid rgba(201,168,76,0.22);
        border-radius: 100px;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--gold-light);
        margin-bottom: 28px;
        animation: fadeDown 0.9s ease-out 0.2s backwards;
        position: relative;
        overflow: hidden;
    }

        .hero-eyebrow::after {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 40%;
            height: 100%;
            background: linear-gradient(90deg,transparent,rgba(255,255,255,0.12),transparent);
            animation: shimmerLine 3.5s ease-in-out infinite;
        }

    .eyebrow-dot {
        width: 5px;
        height: 5px;
        background: var(--gold-accent);
        border-radius: 50%;
        animation: dotPulse 2s ease-in-out infinite;
    }

    .contact-hero h1 {
        font-size: clamp(2.8rem,5.5vw,4.6rem);
        font-weight: 300;
        line-height: 1.1;
        letter-spacing: -0.03em;
        margin-bottom: 22px;
        animation: fadeDown 0.9s ease-out 0.35s backwards;
    }

        .contact-hero h1 strong {
            font-weight: 800;
            display: block;
            background: linear-gradient(120deg,#FFFFFF 0%,#A8CBFF 50%,#FFFFFF 100%);
            background-size: 200% 200%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: gradientShift 6s ease infinite 1s;
        }

    .hero-divider {
        width: 56px;
        height: 2px;
        background: linear-gradient(90deg,var(--gold-accent),transparent);
        margin: 22px auto;
        animation: lineGrow 1s ease-out 0.6s backwards;
    }

    .contact-hero p {
        font-size: clamp(1rem,1.8vw,1.18rem);
        color: var(--text-muted);
        line-height: 1.78;
        max-width: 580px;
        margin: 0 auto;
        animation: fadeDown 0.9s ease-out 0.55s backwards;
    }

    .hero-scroll {
        position: absolute;
        bottom: 40px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        z-index: 1;
        animation: fadeIn 1.2s ease-out 1.1s backwards;
    }

        .hero-scroll span {
            font-size: 0.62rem;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--text-subtle);
            font-weight: 600;
        }

    .scroll-line {
        width: 1px;
        height: 48px;
        background: linear-gradient(180deg,var(--gold-accent),transparent);
        animation: float 2s ease-in-out infinite;
    }

    /* ===================== SECTION LABEL ===================== */
    .section-label {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 3px;
        color: var(--gold-accent);
        margin-bottom: 20px;
    }

        .section-label::before {
            content: "";
            width: 24px;
            height: 1px;
            background: var(--gold-accent);
        }

    /* ===================== MAIN CONTENT ===================== */
    .contact-body {
        padding: 100px 7% 110px;
        position: relative;
        background: linear-gradient(180deg,var(--navy-deep) 0%,#091829 60%,var(--navy-deep) 100%);
    }

        .contact-body::before {
            content: "";
            position: absolute;
            inset: 0;
            background-image: radial-gradient(rgba(59,130,246,0.028) 1px,transparent 1px);
            background-size: 40px 40px;
            pointer-events: none;
        }

    .contact-layout {
        max-width: 1260px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1.4fr;
        gap: 60px;
        align-items: start;
    }

    /* ===================== LEFT SIDE ===================== */
    .contact-left {
        animation: fadeLeft 0.9s ease-out 0.2s backwards;
    }

        .contact-left h2 {
            font-size: clamp(1.9rem,3.5vw,2.8rem);
            font-weight: 300;
            line-height: 1.2;
            letter-spacing: -0.025em;
            margin-bottom: 18px;
        }

            .contact-left h2 strong {
                font-weight: 800;
            }

        .contact-left .lead {
            font-size: clamp(1rem,1.6vw,1.1rem);
            color: var(--text-muted);
            line-height: 1.78;
            margin-bottom: 48px;
        }

    /* Info items */
    .info-stack {
        display: flex;
        flex-direction: column;
        gap: 20px;
        margin-bottom: 48px;
    }

    .info-item {
        display: flex;
        align-items: flex-start;
        gap: 18px;
        padding: 22px 24px;
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        backdrop-filter: blur(10px);
        transition: all 0.35s ease;
        position: relative;
        overflow: hidden;
    }

        .info-item::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg,var(--gold-accent),transparent);
            opacity: 0;
            transition: opacity 0.35s;
        }

        .info-item:hover {
            border-color: rgba(255,255,255,0.15);
            transform: translateX(6px);
        }

            .info-item:hover::before {
                opacity: 1;
            }

    .info-icon {
        width: 46px;
        height: 46px;
        flex-shrink: 0;
        border-radius: 12px;
        background: rgba(201,168,76,0.1);
        border: 1px solid rgba(201,168,76,0.25);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.35s;
        animation: iconPulse 4s ease-in-out infinite;
    }

    .info-item:hover .info-icon {
        background: rgba(201,168,76,0.2);
        border-color: rgba(201,168,76,0.5);
    }

    .info-icon svg {
        width: 20px;
        height: 20px;
    }

    .info-text {
        flex: 1;
        min-width: 0;
    }

    .info-label {
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--gold-accent);
        margin-bottom: 6px;
    }

    .info-value {
        font-size: 0.97rem;
        color: var(--text-muted);
        line-height: 1.65;
    }

        .info-value a {
            color: var(--text-muted);
            text-decoration: none;
            display: block;
            transition: color 0.2s;
        }

            .info-value a:hover {
                color: #fff;
            }

    /* Social row */
    .social-row {
        display: flex;
        gap: 12px;
    }

    .social-btn {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        color: var(--text-muted);
        transition: all 0.25s ease;
    }

        .social-btn:hover {
            background: rgba(201,168,76,0.12);
            border-color: rgba(201,168,76,0.4);
            color: var(--gold-light);
            transform: translateY(-3px);
        }

        .social-btn svg {
            width: 18px;
            height: 18px;
        }

    /* ===================== RIGHT SIDE — CARDS ===================== */
    .contact-right {
        animation: fadeRight 0.9s ease-out 0.35s backwards;
    }

    .cards-header {
        margin-bottom: 28px;
    }

        .cards-header p {
            font-size: 0.88rem;
            color: var(--text-subtle);
        }

    .contact-cards {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
        margin-bottom: 32px;
    }

    .contact-card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 18px;
        padding: 30px 24px;
        text-align: center;
        position: relative;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.4,0,0.2,1);
        backdrop-filter: blur(10px);
        animation: cardReveal 0.6s ease-out backwards;
    }

        .contact-card:nth-child(1) {
            animation-delay: 0.1s;
        }

        .contact-card:nth-child(2) {
            animation-delay: 0.18s;
        }

        .contact-card:nth-child(3) {
            animation-delay: 0.26s;
        }

        .contact-card:nth-child(4) {
            animation-delay: 0.34s;
        }

        /* Gold top bar */
        .contact-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg,var(--gold-accent),var(--gold-light),var(--gold-accent));
            background-size: 200% 100%;
            opacity: 0;
            transition: opacity 0.35s;
            z-index: 2;
            animation: shimmerLine 3s linear infinite;
        }

        .contact-card::after {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 50% 100%,rgba(37,99,176,0.1) 0%,transparent 70%);
            opacity: 0;
            transition: opacity 0.4s;
            pointer-events: none;
        }

        .contact-card:hover {
            transform: translateY(-8px);
            border-color: rgba(255,255,255,0.15);
            box-shadow: 0 20px 55px rgba(0,0,0,0.45),0 0 30px rgba(37,99,176,0.1);
            background: rgba(11,29,53,0.9);
        }

            .contact-card:hover::before {
                opacity: 1;
            }

            .contact-card:hover::after {
                opacity: 1;
            }

    .card-icon {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        background: rgba(201,168,76,0.1);
        border: 1px solid rgba(201,168,76,0.25);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 18px;
        transition: all 0.35s;
    }

    .contact-card:hover .card-icon {
        background: rgba(201,168,76,0.2);
        border-color: rgba(201,168,76,0.5);
        transform: scale(1.08);
    }

    .card-icon svg {
        width: 24px;
        height: 24px;
    }

    .contact-card h3 {
        font-size: 1rem;
        font-weight: 700;
        color: rgba(255,255,255,0.9);
        margin-bottom: 12px;
        letter-spacing: -0.01em;
        position: relative;
        padding-bottom: 12px;
    }

        .contact-card h3::after {
            content: "";
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 24px;
            height: 1px;
            background: var(--gold-accent);
            transition: width 0.35s;
        }

    .contact-card:hover h3::after {
        width: 60%;
    }

    .contact-card p,
    .contact-card a {
        font-size: 0.88rem;
        color: var(--text-muted);
        line-height: 1.75;
        text-decoration: none;
        display: block;
        transition: color 0.25s;
    }

        .contact-card a:hover {
            color: var(--gold-light);
        }

    /* ===================== MAP ===================== */
    .map-wrap {
        border-radius: 18px;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.08);
        box-shadow: 0 20px 60px rgba(0,0,0,0.4);
        position: relative;
        animation: cardReveal 0.7s ease-out 0.5s backwards;
    }

        .map-wrap::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg,var(--gold-accent),var(--gold-light),var(--gold-accent));
            background-size: 200% 100%;
            z-index: 2;
            animation: shimmerLine 4s linear infinite;
        }

        .map-wrap iframe {
            width: 100%;
            height: 360px;
            border: 0;
            display: block;
            filter: invert(0.9) hue-rotate(180deg) brightness(0.85) saturate(0.6);
        }

    /* ===================== VISION QUOTE ===================== */
    .vision-section {
        padding: 110px 7%;
        background: linear-gradient(160deg,#050D1A 0%,#0B1D35 50%,#050D1A 100%);
        border-top: 1px solid rgba(255,255,255,0.05);
        border-bottom: 1px solid rgba(255,255,255,0.05);
        position: relative;
        overflow: hidden;
        text-align: center;
    }

        .vision-section::before {
            content: "";
            position: absolute;
            width: 600px;
            height: 600px;
            border-radius: 50%;
            background: radial-gradient(circle,rgba(59,130,246,0.06) 0%,transparent 70%);
            top: 50%;
            left: 50%;
            transform: translate(-50%,-50%);
            pointer-events: none;
        }

    .vision-quote {
        position: relative;
        max-width: 860px;
        margin: 0 auto;
    }

    .vision-mark {
        font-size: 7rem;
        line-height: 0.6;
        font-family: Georgia,serif;
        color: rgba(201,168,76,0.15);
        display: block;
        margin-bottom: 24px;
        user-select: none;
    }

    .vision-text {
        font-size: clamp(1.4rem,3vw,2.2rem);
        font-weight: 300;
        line-height: 1.65;
        letter-spacing: -0.01em;
        color: rgba(255,255,255,0.9);
    }

        .vision-text strong {
            font-weight: 700;
            color: #fff;
        }

    /* ===================== CTA ===================== */
    .cta-section {
        padding: 130px 7%;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .cta-section::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(160deg,rgba(26,74,138,0.9) 0%,rgba(37,99,176,0.85) 50%,rgba(11,29,53,0.95) 100%);
            z-index: -1;
        }

        .cta-section::after {
            content: "";
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(255,255,255,0.03) 1px,transparent 1px), linear-gradient(90deg,rgba(255,255,255,0.03) 1px,transparent 1px);
            background-size: 60px 60px;
            z-index: -1;
        }

        .cta-section h2 {
            font-size: clamp(2.3rem,4.2vw,3.4rem);
            font-weight: 300;
            letter-spacing: -0.025em;
            margin-bottom: 20px;
        }

            .cta-section h2 strong {
                font-weight: 800;
            }

        .cta-section p {
            max-width: 560px;
            margin: 0 auto 48px;
            color: var(--text-muted);
            font-size: clamp(1rem,1.7vw,1.12rem);
            line-height: 1.75;
            animation: fadeUp 0.8s ease-out 0.2s backwards;
        }

    .cta-actions {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
        animation: fadeUp 0.8s ease-out 0.35s backwards;
    }

    .btn-primary {
        position: relative;
        background: linear-gradient(135deg,var(--blue-primary),var(--blue-soft));
        color: #fff;
        padding: 15px 38px;
        border-radius: 8px;
        font-weight: 700;
        font-size: 0.95rem;
        letter-spacing: 0.03em;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
        box-shadow: 0 4px 24px rgba(26,74,138,0.35),inset 0 1px 0 rgba(255,255,255,0.1);
        overflow: hidden;
    }

        .btn-primary::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg,rgba(255,255,255,0.12),transparent);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 40px rgba(26,74,138,0.5);
        }

            .btn-primary:hover::before {
                opacity: 1;
            }

    .btn-secondary {
        border: 1.5px solid rgba(255,255,255,0.2);
        color: var(--text-white);
        padding: 15px 38px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.95rem;
        letter-spacing: 0.03em;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
        backdrop-filter: blur(8px);
        background: rgba(255,255,255,0.04);
    }

        .btn-secondary:hover {
            border-color: rgba(255,255,255,0.45);
            background: rgba(255,255,255,0.08);
            transform: translateY(-3px);
        }

    /* ===================== RESPONSIVE ===================== */
    @@media (max-width:1100px) {
        .contact-layout {
            grid-template-columns: 1fr;
            gap: 56px;
        }

        .contact-left .lead {
            margin-bottom: 36px;
        }
    }

    @@media (max-width:992px) {
        .contact-hero {
            padding: 150px 6% 110px;
        }

        .contact-body {
            padding: 80px 6% 90px;
        }
    }

    @@media (max-width:768px) {
        .contact-hero {
            padding: 130px 5% 90px;
            min-height: 58vh;
        }

        .contact-body {
            padding: 70px 5% 80px;
        }

        .contact-cards {
