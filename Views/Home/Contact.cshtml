@{
    ViewData["Title"] = "Contact Us";
}

<style>
    :root {
        --navy-deep: #060F1E;
        --navy-main: #0B1D35;
        --blue-primary: #1A4A8A;
        --blue-soft: #2563B0;
        --gold-accent: #C9A84C;
        --gold-light: #E8C96A;
        --text-white: #FFFFFF;
        --text-muted: rgba(255,255,255,0.72);
        --text-subtle: rgba(255,255,255,0.42);
        --glass-bg: rgba(11,29,53,0.65);
        --glass-border: rgba(255,255,255,0.09);
    }

    *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html {
        scroll-behavior: smooth;
    }

    html, body {
        max-width: 100%;
        overflow-x: hidden;
    }

    body {
        background: var(--navy-deep);
        color: var(--text-white);
        font-family: 'Segoe UI','Helvetica Neue',system-ui,sans-serif;
        -webkit-font-smoothing: antialiased;
    }

    /* ===================== ANIMATIONS ===================== */
    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(32px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    @@keyframes fadeDown {
        from {
            opacity: 0;
            transform: translateY(-24px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0
        }

        to {
            opacity: 1
        }
    }

    @@keyframes fadeLeft {
        from {
            opacity: 0;
            transform: translateX(-36px)
        }

        to {
            opacity: 1;
            transform: translateX(0)
        }
    }

    @@keyframes fadeRight {
        from {
            opacity: 0;
            transform: translateX(36px)
        }

        to {
            opacity: 1;
            transform: translateX(0)
        }
    }

    @@keyframes shimmerLine {
        0% {
            transform: translateX(-100%)
        }

        100% {
            transform: translateX(200%)
        }
    }

    @@keyframes gradientShift {
        0%, 100% {
            background-position: 0% 50%
        }

        50% {
            background-position: 100% 50%
        }
    }

    @@keyframes dotPulse {
        0%, 100% {
            opacity: 1;
            transform: scale(1)
        }

        50% {
            opacity: .5;
            transform: scale(.7)
        }
    }

    @@keyframes scanLine {
        0% {
            top: -4px
        }

        100% {
            top: 100%
        }
    }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0)
        }

        50% {
            transform: translateY(-12px)
        }
    }

    @@keyframes lineGrow {
        from {
            width: 0
        }

        to {
            width: 56px
        }
    }

    @@keyframes cardReveal {
        from {
            opacity: 0;
            transform: translateY(28px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    @@keyframes iconPulse {
        0%, 100% {
            box-shadow: 0 0 0 0 rgba(201,168,76,0)
        }

        50% {
            box-shadow: 0 0 0 10px rgba(201,168,76,.08)
        }
    }

    /* ===================== HERO ===================== */
    .contact-hero {
        min-height: 72vh;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 170px 7% 140px;
        overflow: hidden;
        isolation: isolate;
        text-align: center;
    }

    .hero-video-bg {
        position: absolute;
        inset: 0;
        z-index: -3;
        overflow: hidden;
    }

        .hero-video-bg video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: .2;
            filter: brightness(.5) saturate(.6) hue-rotate(200deg);
        }

    .hero-overlay-base {
        position: absolute;
        inset: 0;
        z-index: -2;
        background: linear-gradient(160deg,rgba(6,15,30,.93) 0%,rgba(11,29,53,.8) 50%,rgba(6,15,30,.97) 100%);
    }

    .hero-overlay-radial {
        position: absolute;
        inset: 0;
        z-index: -1;
        background: radial-gradient(ellipse 70% 60% at 50% 50%,rgba(37,99,176,.14) 0%,transparent 70%),radial-gradient(ellipse 35% 25% at 75% 20%,rgba(201,168,76,.07) 0%,transparent 60%);
    }

    .contact-hero::after {
        content: "";
        position: absolute;
        inset: 0;
        background-image: linear-gradient(rgba(255,255,255,.022) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.022) 1px,transparent 1px);
        background-size: 80px 80px;
        z-index: -1;
        pointer-events: none;
    }

    .hero-scanline {
        position: absolute;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg,transparent,rgba(59,130,246,.22),transparent);
        z-index: 0;
        animation: scanLine 10s linear infinite;
        pointer-events: none;
    }

    .hero-inner {
        position: relative;
        z-index: 1;
        max-width: 800px;
        margin: 0 auto;
        animation: fadeIn 1.2s ease-out;
    }

    .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 7px 20px;
        background: rgba(201,168,76,.08);
        border: 1px solid rgba(201,168,76,.22);
        border-radius: 100px;
        font-size: .7rem;
        font-weight: 700;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--gold-light);
        margin-bottom: 28px;
        animation: fadeDown .9s ease-out .2s backwards;
        position: relative;
        overflow: hidden;
    }

        .hero-eyebrow::after {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 40%;
            height: 100%;
            background: linear-gradient(90deg,transparent,rgba(255,255,255,.12),transparent);
            animation: shimmerLine 3.5s ease-in-out infinite;
        }

    .eyebrow-dot {
        width: 5px;
        height: 5px;
        background: var(--gold-accent);
        border-radius: 50%;
        animation: dotPulse 2s ease-in-out infinite;
    }

    .contact-hero h1 {
        font-size: clamp(2.8rem,5.5vw,4.8rem);
        font-weight: 300;
        line-height: 1.1;
        letter-spacing: -.03em;
        margin-bottom: 22px;
        animation: fadeDown .9s ease-out .35s backwards;
    }

        .contact-hero h1 strong {
            font-weight: 800;
            display: block;
            background: linear-gradient(120deg,#FFFFFF 0%,#A8CBFF 50%,#FFFFFF 100%);
            background-size: 200% 200%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: gradientShift 6s ease infinite 1s;
        }

    .hero-divider {
        width: 56px;
        height: 2px;
        background: linear-gradient(90deg,var(--gold-accent),transparent);
        margin: 22px auto;
        animation: lineGrow 1s ease-out .6s backwards;
    }

    .contact-hero > .hero-inner > p {
        font-size: clamp(1rem,1.8vw,1.18rem);
        color: var(--text-muted);
        line-height: 1.78;
        max-width: 580px;
        margin: 0 auto;
        animation: fadeDown .9s ease-out .55s backwards;
    }

    .hero-stats {
        display: flex;
        justify-content: center;
        gap: 40px;
        margin-top: 48px;
        animation: fadeUp .9s ease-out .75s backwards;
        flex-wrap: wrap;
    }

    .hero-stat {
        text-align: center;
    }

    .hero-stat-val {
        font-size: 1.8rem;
        font-weight: 800;
        letter-spacing: -.03em;
        background: linear-gradient(135deg,#fff,rgba(201,168,76,.9));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        line-height: 1;
    }

    .hero-stat-lbl {
        font-size: .65rem;
        text-transform: uppercase;
        letter-spacing: 2.5px;
        color: var(--text-subtle);
        font-weight: 600;
        margin-top: 4px;
    }

    .hero-stat-div {
        width: 1px;
        background: rgba(255,255,255,.1);
        align-self: stretch;
    }

    .hero-scroll {
        position: absolute;
        bottom: 40px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        z-index: 1;
        animation: fadeIn 1.2s ease-out 1.1s backwards;
    }

        .hero-scroll span {
            font-size: .62rem;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--text-subtle);
            font-weight: 600;
        }

    .scroll-line {
        width: 1px;
        height: 48px;
        background: linear-gradient(180deg,var(--gold-accent),transparent);
        animation: float 2s ease-in-out infinite;
    }

    /* ===================== SECTION LABEL ===================== */
    .section-label {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: .68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 3px;
        color: var(--gold-accent);
        margin-bottom: 20px;
    }

        .section-label::before {
            content: "";
            width: 24px;
            height: 1px;
            background: var(--gold-accent);
        }

    /* ===================== BODY ===================== */
    .contact-body {
        padding: 120px 7% 130px;
        position: relative;
        background: linear-gradient(180deg,var(--navy-deep) 0%,#091829 55%,var(--navy-deep) 100%);
    }

        .contact-body::before {
            content: "";
            position: absolute;
            inset: 0;
            background-image: radial-gradient(rgba(59,130,246,.028) 1px,transparent 1px);
            background-size: 40px 40px;
            pointer-events: none;
        }

    .contact-layout {
        max-width: 1320px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1.55fr;
        gap: 72px;
        align-items: start;
    }

    /* ===================== LEFT ===================== */
    .contact-left {
        animation: fadeLeft .9s ease-out .2s backwards;
    }

        .contact-left h2 {
            font-size: clamp(1.9rem,3.5vw,2.8rem);
            font-weight: 300;
            line-height: 1.2;
            letter-spacing: -.025em;
            margin-bottom: 14px;
        }

            .contact-left h2 strong {
                font-weight: 800;
            }

        .contact-left .lead {
            font-size: clamp(.97rem,1.6vw,1.06rem);
            color: var(--text-muted);
            line-height: 1.82;
            margin-bottom: 36px;
            max-width: 420px;
        }

    /* Info items */
    .info-stack {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-bottom: 36px;
    }

    .info-item {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 18px 20px;
        background: rgba(11,29,53,.6);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        backdrop-filter: blur(12px);
        transition: border-color .3s, transform .3s, background .3s;
        position: relative;
        overflow: hidden;
        cursor: default;
    }
        /* Gold left accent on hover */
        .info-item::after {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            bottom: 0;
            width: 3px;
            background: linear-gradient(180deg,var(--gold-accent),rgba(201,168,76,.2));
            opacity: 0;
            transition: opacity .3s;
            border-radius: 3px 0 0 3px;
        }

        .info-item:hover {
            border-color: rgba(255,255,255,.14);
            transform: translateX(5px);
            background: rgba(11,29,53,.82);
        }

            .info-item:hover::after {
                opacity: 1;
            }

    .info-icon {
        width: 46px;
        height: 46px;
        flex-shrink: 0;
        border-radius: 12px;
        background: rgba(201,168,76,.09);
        border: 1px solid rgba(201,168,76,.22);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all .3s;
        animation: iconPulse 4s ease-in-out infinite;
    }

    .info-item:hover .info-icon {
        background: rgba(201,168,76,.18);
        border-color: rgba(201,168,76,.48);
    }

    .info-icon svg {
        width: 19px;
        height: 19px;
    }

    .info-text {
        flex: 1;
        min-width: 0;
    }

    .info-label {
        font-size: .62rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2.2px;
        color: var(--gold-accent);
        margin-bottom: 4px;
    }

    .info-value {
        font-size: .9rem;
        color: var(--text-muted);
        line-height: 1.6;
    }

        .info-value a {
            color: var(--text-muted);
            text-decoration: none;
            display: block;
            transition: color .2s;
        }

            .info-value a:hover {
                color: #fff;
            }

    /* Social */
    .social-heading {
        font-size: .62rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2.5px;
        color: var(--gold-accent);
        margin-bottom: 12px;
    }

    .social-row {
        display: flex;
        gap: 10px;
    }

    .social-btn {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.09);
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        color: var(--text-subtle);
        transition: all .25s ease;
    }

        .social-btn:hover {
            background: rgba(201,168,76,.12);
            border-color: rgba(201,168,76,.38);
            color: var(--gold-light);
            transform: translateY(-3px);
        }

        .social-btn svg {
            width: 17px;
            height: 17px;
        }

    /* ===================== RIGHT ===================== */
    .contact-right {
        animation: fadeRight .9s ease-out .35s backwards;
        display: flex;
        flex-direction: column;
        gap: 22px;
    }

    /* Quick cards */
    .contact-cards {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 14px;
    }

    .contact-card {
        background: rgba(11,29,53,.6);
        border: 1px solid var(--glass-border);
        border-radius: 18px;
        padding: 28px 20px;
        text-align: center;
        position: relative;
        overflow: hidden;
        transition: all .4s cubic-bezier(.4,0,.2,1);
        backdrop-filter: blur(12px);
        animation: cardReveal .6s ease-out backwards;
    }

        .contact-card:nth-child(1) {
            animation-delay: .08s
        }

        .contact-card:nth-child(2) {
            animation-delay: .16s
        }

        .contact-card:nth-child(3) {
            animation-delay: .24s
        }

        .contact-card:nth-child(4) {
            animation-delay: .32s
        }

        /* Gold shimmer top bar */
        .contact-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg,var(--gold-accent),var(--gold-light),var(--gold-accent));
            background-size: 200% 100%;
            opacity: 0;
            transition: opacity .35s;
            z-index: 2;
            animation: shimmerLine 3s linear infinite;
        }

        .contact-card:hover {
            transform: translateY(-7px);
            border-color: rgba(255,255,255,.14);
            box-shadow: 0 20px 50px rgba(0,0,0,.4),0 0 28px rgba(37,99,176,.09);
            background: rgba(11,29,53,.88);
        }

            .contact-card:hover::before {
                opacity: 1;
            }

    .card-icon {
        width: 50px;
        height: 50px;
        border-radius: 13px;
        background: rgba(201,168,76,.09);
        border: 1px solid rgba(201,168,76,.22);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 14px;
        transition: all .3s;
    }

    .contact-card:hover .card-icon {
        background: rgba(201,168,76,.18);
        border-color: rgba(201,168,76,.5);
        transform: scale(1.06);
    }

    .card-icon svg {
        width: 21px;
        height: 21px;
    }

    .contact-card h3 {
        font-size: .9rem;
        font-weight: 700;
        color: rgba(255,255,255,.88);
        margin-bottom: 10px;
        position: relative;
        padding-bottom: 10px;
    }

        .contact-card h3::after {
            content: "";
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 20px;
            height: 1px;
            background: var(--gold-accent);
            transition: width .35s;
        }

    .contact-card:hover h3::after {
        width: 55%;
    }

    .contact-card p, .contact-card a {
        font-size: .82rem;
        color: var(--text-muted);
        line-height: 1.7;
        text-decoration: none;
        display: block;
        transition: color .25s;
    }

        .contact-card a:hover {
            color: var(--gold-light);
        }

    /* ===================== MAP ===================== */
    .map-outer {
        position: relative;
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,.09);
        box-shadow: 0 28px 70px rgba(0,0,0,.48);
        animation: cardReveal .7s ease-out .48s backwards;
    }
        /* Animated gold top bar */
        .map-outer::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg,var(--gold-accent),var(--gold-light),var(--gold-accent));
            background-size: 200% 100%;
            z-index: 10;
            animation: shimmerLine 4s linear infinite;
        }

    .map-label {
        position: absolute;
        top: 16px;
        left: 16px;
        z-index: 5;
        background: rgba(6,15,30,.9);
        backdrop-filter: blur(18px);
        border: 1px solid rgba(255,255,255,.11);
        border-radius: 10px;
        padding: 10px 14px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .map-label-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--gold-accent);
        animation: dotPulse 2s ease-in-out infinite;
    }

    .map-label-text {
        font-size: .74rem;
        font-weight: 700;
        color: rgba(255,255,255,.85);
        letter-spacing: .4px;
    }

    .map-label-sub {
        font-size: .63rem;
        color: var(--text-subtle);
        margin-top: 2px;
    }

    .map-outer iframe {
        width: 100%;
        height: 400px;
        border: 0;
        display: block;
        filter: invert(.9) hue-rotate(180deg) brightness(.82) saturate(.55);
        transition: filter .4s;
    }

    .map-outer:hover iframe {
        filter: invert(.85) hue-rotate(180deg) brightness(.88) saturate(.68);
    }

    .map-footer {
        background: rgba(6,15,30,.78);
        backdrop-filter: blur(18px);
        border-top: 1px solid rgba(255,255,255,.07);
        padding: 14px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
    }

    .map-address {
        font-size: .78rem;
        color: var(--text-subtle);
        line-height: 1.55;
    }

        .map-address strong {
            color: rgba(255,255,255,.68);
            display: block;
            margin-bottom: 2px;
        }

    .map-open-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 8px 16px;
        border-radius: 8px;
        background: rgba(201,168,76,.1);
        border: 1px solid rgba(201,168,76,.28);
        color: var(--gold-light);
        font-size: .74rem;
        font-weight: 700;
        letter-spacing: .05em;
        text-transform: uppercase;
        text-decoration: none;
        white-space: nowrap;
        transition: all .25s ease;
    }

        .map-open-btn:hover {
            background: rgba(201,168,76,.2);
            border-color: rgba(201,168,76,.58);
            color: #fff;
            transform: translateY(-2px);
        }

        .map-open-btn svg {
            width: 13px;
            height: 13px;
        }

    /* ===================== VISION ===================== */
    .vision-section {
        padding: 110px 7%;
        background: linear-gradient(160deg,#050D1A 0%,#0B1D35 50%,#050D1A 100%);
        border-top: 1px solid rgba(255,255,255,.05);
        border-bottom: 1px solid rgba(255,255,255,.05);
        position: relative;
        overflow: hidden;
        text-align: center;
    }

        .vision-section::before {
            content: "";
            position: absolute;
            width: 600px;
            height: 600px;
            border-radius: 50%;
            background: radial-gradient(circle,rgba(59,130,246,.06) 0%,transparent 70%);
            top: 50%;
            left: 50%;
            transform: translate(-50%,-50%);
            pointer-events: none;
        }

    .vision-quote {
        position: relative;
        max-width: 860px;
        margin: 0 auto;
    }

    .vision-mark {
        font-size: 7rem;
        line-height: .6;
        font-family: Georgia,serif;
        color: rgba(201,168,76,.15);
        display: block;
        margin-bottom: 24px;
        user-select: none;
    }

    .vision-text {
        font-size: clamp(1.4rem,3vw,2.2rem);
        font-weight: 300;
        line-height: 1.65;
        letter-spacing: -.01em;
        color: rgba(255,255,255,.9);
    }

        .vision-text strong {
            font-weight: 700;
            color: #fff;
        }

    /* ===================== CTA ===================== */
    .cta-section {
        padding: 130px 7%;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .cta-section::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(160deg,rgba(26,74,138,.9) 0%,rgba(37,99,176,.85) 50%,rgba(11,29,53,.95) 100%);
            z-index: -1;
        }

        .cta-section::after {
            content: "";
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px);
            background-size: 60px 60px;
            z-index: -1;
        }

        .cta-section h2 {
            font-size: clamp(2.3rem,4.2vw,3.4rem);
            font-weight: 300;
            letter-spacing: -.025em;
            margin-bottom: 20px;
        }

            .cta-section h2 strong {
                font-weight: 800;
            }

        .cta-section p {
            max-width: 560px;
            margin: 0 auto 48px;
            color: var(--text-muted);
