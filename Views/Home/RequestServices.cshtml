@model RequestServiceViewModel

@{
    ViewData["Title"] = "Request Services";
}

<style>
    :root {
        --navy-deep: #060F1E;
        --navy-main: #0B1D35;
        --blue-primary: #1A4A8A;
        --blue-soft: #2563B0;
        --blue-glow: #3B82F6;
        --gold-accent: #C9A84C;
        --gold-light: #E8C96A;
        --text-white: #FFFFFF;
        --text-muted: rgba(255,255,255,0.72);
        --text-subtle: rgba(255,255,255,0.42);
        --glass-bg: rgba(11,29,53,0.7);
        --glass-border: rgba(255,255,255,0.09);
        --glass-border-hover: rgba(255,255,255,0.18);
        --input-bg: rgba(6,15,30,0.6);
        --input-border: rgba(255,255,255,0.12);
        --input-border-focus: rgba(37,99,176,0.7);
    }

    *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        background: var(--navy-deep);
        color: var(--text-white);
        overflow-x: hidden;
        font-family: 'Segoe UI', 'Helvetica Neue', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
    }

    html, body {
    max-width: 100%;
    overflow-x: hidden;
}

    /* ===================== ANIMATIONS ===================== */
    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(32px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeDown {
        from {
            opacity: 0;
            transform: translateY(-24px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes shimmerLine {
        0% {
            transform: translateX(-100%);
        }

        100% {
            transform: translateX(200%);
        }
    }

    @@keyframes gradientShift {
        0%, 100% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }
    }

    @@keyframes dotPulse {
        0%, 100% {
            opacity: 1;
            transform: scale(1);
        }

        50% {
            opacity: 0.5;
            transform: scale(0.7);
        }
    }

    @@keyframes scanLine {
        0% {
            top: -4px;
        }

        100% {
            top: 100%;
        }
    }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-12px);
        }
    }

    @@keyframes lineGrow {
        from {
            width: 0;
        }

        to {
            width: 56px;
        }
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            max-height: 0;
            transform: translateY(-8px);
        }

        to {
            opacity: 1;
            max-height: 400px;
            transform: translateY(0);
        }
    }

    @@keyframes checkPop {
        0% {
            transform: scale(0.7);
        }

        70% {
            transform: scale(1.15);
        }

        100% {
            transform: scale(1);
        }
    }

    /* ===================== HERO ===================== */
    .req-hero {
        min-height: 62vh;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 160px 7% 120px;
        overflow: hidden;
        isolation: isolate;
        text-align: center;
    }

    .hero-video-bg {
        position: absolute;
        inset: 0;
        z-index: -3;
        overflow: hidden;
    }

        .hero-video-bg video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.2;
            filter: brightness(0.5) saturate(0.6) hue-rotate(200deg);
        }

    .hero-overlay-base {
        position: absolute;
        inset: 0;
        z-index: -2;
        background: linear-gradient(160deg,rgba(6,15,30,0.92) 0%,rgba(11,29,53,0.78) 50%,rgba(6,15,30,0.96) 100%);
    }

    .hero-overlay-radial {
        position: absolute;
        inset: 0;
        z-index: -1;
        background: radial-gradient(ellipse 70% 60% at 50% 50%,rgba(37,99,176,0.14) 0%,transparent 70%), radial-gradient(ellipse 35% 25% at 75% 20%,rgba(201,168,76,0.07) 0%,transparent 60%);
    }

    .req-hero::after {
        content: "";
        position: absolute;
        inset: 0;
        background-image: linear-gradient(rgba(255,255,255,0.022) 1px,transparent 1px), linear-gradient(90deg,rgba(255,255,255,0.022) 1px,transparent 1px);
        background-size: 80px 80px;
        z-index: -1;
        pointer-events: none;
    }

    .hero-scanline {
        position: absolute;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg,transparent,rgba(59,130,246,0.22),transparent);
        z-index: 0;
        animation: scanLine 10s linear infinite;
        pointer-events: none;
    }

    .hero-inner {
        position: relative;
        z-index: 1;
        max-width: 760px;
        margin: 0 auto;
        animation: fadeIn 1.2s ease-out;
    }

    .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 7px 20px;
        background: rgba(201,168,76,0.08);
        border: 1px solid rgba(201,168,76,0.22);
        border-radius: 100px;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--gold-light);
        margin-bottom: 28px;
        animation: fadeDown 0.9s ease-out 0.2s backwards;
        position: relative;
        overflow: hidden;
    }

        .hero-eyebrow::after {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 40%;
            height: 100%;
            background: linear-gradient(90deg,transparent,rgba(255,255,255,0.12),transparent);
            animation: shimmerLine 3.5s ease-in-out infinite;
        }

    .eyebrow-dot {
        width: 5px;
        height: 5px;
        background: var(--gold-accent);
        border-radius: 50%;
        animation: dotPulse 2s ease-in-out infinite;
    }

    .req-hero h1 {
        font-size: clamp(2.6rem,5.5vw,4.4rem);
        font-weight: 300;
        line-height: 1.12;
        letter-spacing: -0.03em;
        margin-bottom: 22px;
        animation: fadeDown 0.9s ease-out 0.35s backwards;
    }

        .req-hero h1 strong {
            font-weight: 800;
            display: block;
            background: linear-gradient(120deg,#FFFFFF 0%,#A8CBFF 50%,#FFFFFF 100%);
            background-size: 200% 200%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: gradientShift 6s ease infinite 1s;
        }

    .hero-divider {
        width: 56px;
        height: 2px;
        background: linear-gradient(90deg,var(--gold-accent),transparent);
        margin: 22px auto;
        animation: lineGrow 1s ease-out 0.6s backwards;
    }

    .req-hero p {
        font-size: clamp(1rem,1.8vw,1.18rem);
        color: var(--text-muted);
        line-height: 1.78;
        max-width: 620px;
        margin: 0 auto;
        animation: fadeDown 0.9s ease-out 0.55s backwards;
    }

    /* ===================== SECTION LABEL ===================== */
    .section-label {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 3px;
        color: var(--gold-accent);
        margin-bottom: 20px;
    }

        .section-label::before {
            content: "";
            width: 24px;
            height: 1px;
            background: var(--gold-accent);
        }

    /* ===================== FORM WRAPPER ===================== */
    .form-section {
        padding: 0 7% 120px;
        position: relative;
        background: linear-gradient(180deg,var(--navy-deep) 0%,#091829 60%,var(--navy-deep) 100%);
    }

        .form-section::before {
            content: "";
            position: absolute;
            inset: 0;
            background-image: radial-gradient(rgba(59,130,246,0.028) 1px,transparent 1px);
            background-size: 40px 40px;
            pointer-events: none;
        }

    .form-outer {
        max-width: 960px;
        margin: -60px auto 0;
        position: relative;
        z-index: 10;
        animation: fadeUp 1s ease-out 0.3s backwards;
    }

    /* Alerts */
    .alert {
        padding: 16px 22px;
        margin-bottom: 28px;
        border-radius: 12px;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 14px;
        animation: fadeDown 0.5s ease-out;
        font-size: 0.95rem;
    }

    .alert-success {
        background: rgba(16,185,129,0.1);
        border: 1px solid rgba(16,185,129,0.35);
        color: #6ee7b7;
    }

    .alert-danger {
        background: rgba(239,68,68,0.1);
        border: 1px solid rgba(239,68,68,0.35);
        color: #fca5a5;
    }

    .alert svg {
        flex-shrink: 0;
    }

    /* Form Card */
    .form-card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 24px;
        padding: 56px 60px;
        backdrop-filter: blur(16px);
        box-shadow: 0 32px 80px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.06);
    }

    /* ===================== SECTION HEADER ===================== */
    .form-section-head {
        margin-bottom: 32px;
        padding-bottom: 20px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        position: relative;
    }

        .form-section-head::after {
            content: "";
            position: absolute;
            bottom: -1px;
            left: 0;
            width: 48px;
            height: 1px;
            background: var(--gold-accent);
        }

        .form-section-head h2 {
            font-size: clamp(1.2rem,2.2vw,1.5rem);
            font-weight: 700;
            color: #fff;
            letter-spacing: -0.01em;
            margin-bottom: 6px;
        }

        .form-section-head p {
            font-size: 0.88rem;
            color: var(--text-subtle);
        }

    .req-star {
        color: var(--gold-accent);
        margin-left: 3px;
    }

    /* ===================== SERVICES GRID ===================== */
    .services-grid {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 14px;
        margin-bottom: 48px;
    }

    .checkbox-item {
        position: relative;
    }

        .checkbox-item input[type="checkbox"] {
            position: absolute;
            opacity: 0;
            width: 0;
            height: 0;
        }

    .checkbox-label {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 16px 18px;
        background: rgba(6,15,30,0.5);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        cursor: pointer;
        font-size: 0.93rem;
        font-weight: 500;
        color: var(--text-muted);
        transition: all 0.25s ease;
        user-select: none;
        width: 100%;
    }

        .checkbox-label:hover {
            background: rgba(37,99,176,0.12);
            border-color: rgba(37,99,176,0.35);
            color: #fff;
        }

    /* Custom checkbox box */
    .cb-box {
        width: 20px;
        height: 20px;
        flex-shrink: 0;
        border: 1.5px solid rgba(255,255,255,0.2);
        border-radius: 6px;
        background: rgba(255,255,255,0.04);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.25s ease;
    }

        .cb-box svg {
            opacity: 0;
            transition: opacity 0.2s;
        }

    .checkbox-item input[type="checkbox"]:checked + .checkbox-label {
        background: rgba(201,168,76,0.1);
        border-color: rgba(201,168,76,0.45);
        color: #fff;
    }

        .checkbox-item input[type="checkbox"]:checked + .checkbox-label .cb-box {
            background: var(--gold-accent);
            border-color: var(--gold-accent);
            animation: checkPop 0.3s ease-out;
        }

            .checkbox-item input[type="checkbox"]:checked + .checkbox-label .cb-box svg {
                opacity: 1;
            }

    /* ===================== FORM ROWS / GROUPS ===================== */
    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        margin-bottom: 24px;
    }

    .form-row-single {
        margin-bottom: 24px;
    }

    .form-group {
        position: relative;
    }

    .form-label {
        display: block;
        font-weight: 600;
        color: rgba(255,255,255,0.85);
        margin-bottom: 10px;
        font-size: 0.9rem;
        letter-spacing: 0.01em;
    }

    .form-control {
        width: 100%;
        padding: 13px 18px;
        background: rgba(6,15,30,0.55);
        border: 1.5px solid var(--input-border);
        border-radius: 10px;
        color: #ffffff !important;
        -webkit-text-fill-color: #ffffff !important;
        font-size: 0.97rem;
        font-family: inherit;
        transition: all 0.3s ease;
        outline: none;
        backdrop-filter: blur(4px);
    }

        .form-control::placeholder {
            color: var(--text-subtle);
        }

        .form-control:hover {
            border-color: rgba(255,255,255,0.2);
        }

        .form-control:focus {
            border-color: var(--input-border-focus);
            background: rgba(6,15,30,0.75);
            box-shadow: 0 0 0 4px rgba(37,99,176,0.15);
        }
        /* Autofill override */
        .form-control:-webkit-autofill,
        .form-control:-webkit-autofill:hover,
        .form-control:-webkit-autofill:focus {
            -webkit-box-shadow: 0 0 0 1000px rgba(6,15,30,0.9) inset !important;
            -webkit-text-fill-color: #fff !important;
            border-color: var(--input-border-focus);
        }

    textarea.form-control {
        resize: vertical;
        min-height: 140px;
    }

    .text-danger {
        color: #fca5a5;
        font-size: 0.82rem;
        margin-top: 6px;
        display: block;
    }

    /* ===================== RADIO GROUP ===================== */
    .radio-group {
        display: flex;
        gap: 14px;
        margin-top: 12px;
        flex-wrap: wrap;
    }

    .radio-item {
        position: relative;
    }

        .radio-item input[type="radio"] {
            position: absolute;
            opacity: 0;
            width: 0;
            height: 0;
        }

    .radio-label {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 22px;
        background: rgba(6,15,30,0.5);
        border: 1.5px solid rgba(255,255,255,0.08);
        border-radius: 10px;
        cursor: pointer;
        font-size: 0.92rem;
        font-weight: 500;
        color: var(--text-muted);
        transition: all 0.25s ease;
        user-select: none;
    }

        .radio-label:hover {
            background: rgba(37,99,176,0.1);
            border-color: rgba(37,99,176,0.3);
            color: #fff;
        }

    .rb-circle {
        width: 18px;
        height: 18px;
        flex-shrink: 0;
        border: 1.5px solid rgba(255,255,255,0.2);
        border-radius: 50%;
        background: rgba(255,255,255,0.04);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.25s ease;
    }

    .rb-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--gold-accent);
        opacity: 0;
        transform: scale(0);
        transition: all 0.2s cubic-bezier(0.4,0,0.2,1);
    }

    .radio-item input[type="radio"]:checked + .radio-label {
        background: rgba(201,168,76,0.1);
        border-color: rgba(201,168,76,0.45);
        color: #fff;
    }

        .radio-item input[type="radio"]:checked + .radio-label .rb-circle {
            border-color: var(--gold-accent);
        }

        .radio-item input[type="radio"]:checked + .radio-label .rb-dot {
            opacity: 1;
            transform: scale(1);
        }

    /* ===================== NOTES TEXTAREA ===================== */
    .notes-panel {
        margin-top: 24px;
        overflow: hidden;
        animation: slideDown 0.4s ease-out;
    }

        .notes-panel.hidden {
            display: none;
        }

    /* ===================== DIVIDER ===================== */
    .form-divider {
        border: none;
        border-top: 1px solid rgba(255,255,255,0.06);
        margin: 40px 0;
    }

    /* ===================== SUBMIT ===================== */
    .submit-wrap {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 20px;
        padding-top: 36px;
        border-top: 1px solid rgba(255,255,255,0.06);
        margin-top: 40px;
    }

    .submit-note {
        font-size: 0.82rem;
        color: var(--text-subtle);
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .submit-note svg {
            flex-shrink: 0;
            opacity: 0.6;
        }

    .btn-submit {
        position: relative;
        background: linear-gradient(135deg,var(--blue-primary),var(--blue-soft));
        color: #fff;
        padding: 16px 48px;
        border: none;
        border-radius: 10px;
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: 0.03em;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 12px;
        transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
        box-shadow: 0 4px 24px rgba(26,74,138,0.35), inset 0 1px 0 rgba(255,255,255,0.1);
        overflow: hidden;
    }

        .btn-submit::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg,rgba(255,255,255,0.12),transparent);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .btn-submit:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 40px rgba(26,74,138,0.5);
        }

            .btn-submit:hover::before {
                opacity: 1;
            }

        .btn-submit:active {
            transform: translateY(0);
        }

        .btn-submit:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }

        .btn-submit span, .btn-submit svg {
            position: relative;
            z-index: 1;
        }

    /* ===================== RESPONSIVE ===================== */
    @@media (max-width:1024px) {
        .services-grid {
            grid-template-columns: repeat(2,1fr);
        }
    }

    @@media (max-width:992px) {
        .req-hero {
            padding: 150px 6% 110px;
        }

        .form-section {
            padding: 0 6% 100px;
        }

        .form-card {
            padding: 48px 48px;
        }
    }

    @@media (max-width:768px) {
        .req-hero {
            padding: 130px 5% 90px;
            min-height: 55vh;
        }

        .form-section {
            padding: 0 5% 80px;
        }

        .form-card {
            padding: 40px 36px;
            border-radius: 18px;
        }

        .services-grid {
            grid-template-columns: repeat(2,1fr);
            gap: 12px;
        }

        .form-row {
            grid-template-columns: 1fr;
            gap: 18px;
        }

        .submit-wrap {
            flex-direction: column;
            align-items: stretch;
        }

        .btn-submit {
            width: 100%;
            justify-content: center;
        }
    }

    @@media (max-width:576px) {
        .req-hero {
            padding: 110px 4% 70px;
        }

        .form-section {
            padding: 0 4% 70px;
        }

        .form-card {
            padding: 30px 22px;
            border-radius: 16px;
        }

        .form-outer {
            margin-top: -40px;
        }

        .services-grid {
            grid-template-columns: 1fr;
            gap: 10px;
        }

        .checkbox-label {
            padding: 14px 16px;
            font-size: 0.88rem;
        }

        .radio-group {
            flex-direction: column;
            gap: 10px;
        }

        .radio-label {
            padding: 12px 18px;
        }
    }
</style>

<!-- ======================== HERO ======================== -->
<section class="req-hero">
    <div class="hero-video-bg">
        <video autoplay muted loop playsinline preload="auto">
            <source src="~/Videos/data_analysis_digital.mov" type="video/mp4" />
        </video>
    </div>
    <div class="hero-overlay-base"></div>
    <div class="hero-overlay-radial"></div>
    <div class="hero-scanline"></div>

    <div class="hero-inner">
        <div class="hero-eyebrow"><span class="eyebrow-dot"></span>Get Started</div>
        <h1>
            Request
            <strong>Our Services</strong>
        </h1>
        <div class="hero-divider"></div>
        <p>Tell us about your needs and our team will get back to you with a tailored solution within 24 hours.</p>
    </div>
</section>

<!-- ======================== FORM ======================== -->
<section class="form-section">
    <div class="form-outer">

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                <svg width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                    <polyline points="22 4 12 14.01 9 11.01" />
                </svg>
                @TempData["SuccessMessage"]
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                <svg width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10" />
                    <line x1="12" y1="8" x2="12" y2="12" />
                    <line x1="12" y1="16" x2="12.01" y2="16" />
                </svg>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="form-card">
            @using (Html.BeginForm("SubmitServiceRequest", "Home", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                <!-- ── SERVICES ── -->
                <div class="form-section-head">
                    <h2>Select Services <span class="req-star">*</span></h2>
                    <p>Choose one or more services you're interested in</p>
                </div>

                <div class="services-grid">
                    <div class="checkbox-item">
                        @Html.CheckBoxFor(m => m.StrategyPlanning, new { id = "s1" })
                        <label for="s1" class="checkbox-label">
                            <span class="cb-box"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg></span>
                            Strategic Planning & Performance
                        </label>
                    </div>
                    <div class="checkbox-item">
                        @Html.CheckBoxFor(m => m.PMO, new { id = "s2" })
                        <label for="s2" class="checkbox-label">
                            <span class="cb-box"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg></span>
                            Project Management (PMO)
                        </label>
                    </div>
                    <div class="checkbox-item">
                        @Html.CheckBoxFor(m => m.Governance, new { id = "s3" })
                        <label for="s3" class="checkbox-label">
                            <span class="cb-box"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg></span>
                            Governance & Risk Management
                        </label>
                    </div>
                    <div class="checkbox-item">
                        @Html.CheckBoxFor(m => m.ISO, new { id = "s4" })
                        <label for="s4" class="checkbox-label">
                            <span class="cb-box"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg></span>
                            ISO & Excellence Models
                        </label>
                    </div>
                    <div class="checkbox-item">
                        @Html.CheckBoxFor(m => m.Digital, new { id = "s5" })
                        <label for="s5" class="checkbox-label">
                            <span class="cb-box"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg></span>
                            Digital & Technology Solutions
                        </label>
                    </div>
                    <div class="checkbox-item">
                        @Html.CheckBoxFor(m => m.Financial, new { id = "s6" })
                        <label for="s6" class="checkbox-label">
                            <span class="cb-box"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg></span>
                            Financial Advisory
                        </label>
                    </div>
                    <div class="checkbox-item">
                        @Html.CheckBoxFor(m => m.Sustainability, new { id = "s7" })
                        <label for="s7" class="checkbox-label">
                            <span class="cb-box"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg></span>
                            Sustainability & Energy
                        </label>
                    </div>
                    <div class="checkbox-item">
                        @Html.CheckBoxFor(m => m.HR, new { id = "s8" })
                        <label for="s8" class="checkbox-label">
                            <span class="cb-box"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg></span>
                            HR & Restructuring
                        </label>
                    </div>
                    <div class="checkbox-item">
                        @Html.CheckBoxFor(m => m.BusinessProcess, new { id = "s9" })
                        <label for="s9" class="checkbox-label">
                            <span class="cb-box"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg></span>
                            Business Process Management
                        </label>
                    </div>
                    <div class="checkbox-item">
                        @Html.CheckBoxFor(m => m.AI, new { id = "s10" })
                        <label for="s10" class="checkbox-label">
                            <span class="cb-box"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg></span>
                            Artificial Intelligence
                        </label>
                    </div>
                    <div class="checkbox-item">
                        @Html.CheckBoxFor(m => m.CyberSecurity, new { id = "s11" })
                        <label for="s11" class="checkbox-label">
                            <span class="cb-box"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg></span>
                            Cyber Security
                        </label>
                    </div>
                </div>
                @Html.ValidationMessage("Services", "", new { @class = "text-danger" })

                <hr class="form-divider" />

                <!-- ── CONTACT INFO ── -->
                <div class="form-section-head">
                    <h2>Contact Information</h2>
                    <p>How can we reach you?</p>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        @Html.LabelFor(m => m.PersonName, new { @class = "form-label" })
                        <span class="req-star" style="position:relative;top:-2px;margin-left:2px;font-size:0.8rem;">*</span>
                        @Html.TextBoxFor(m => m.PersonName, new { @class = "form-control", placeholder = "" })
                        @Html.ValidationMessageFor(m => m.PersonName, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(m => m.Email, new { @class = "form-label" })
                        <span class="req-star" style="position:relative;top:-2px;margin-left:2px;font-size:0.8rem;">*</span>
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control", type = "email", placeholder = "" })
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        @Html.LabelFor(m => m.MobileNumber, new { @class = "form-label" })
                        <span class="req-star" style="position:relative;top:-2px;margin-left:2px;font-size:0.8rem;">*</span>
                        @Html.TextBoxFor(m => m.MobileNumber, new { @class = "form-control", type = "tel", placeholder = "" })
                        @Html.ValidationMessageFor(m => m.MobileNumber, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(m => m.CompanyName, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.CompanyName, new { @class = "form-control", placeholder = "" })
                    </div>
                </div>

                <hr class="form-divider" />

                <!-- ── NOTES ── -->
                <div class="form-section-head">
                    <h2>Additional Information</h2>
                    <p>Would you like to add any further details?</p>
                </div>

                <div class="form-group">
                    <label class="form-label">Add a note? <span class="req-star">*</span></label>
                    <div class="radio-group">
                        <div class="radio-item">
                            @Html.RadioButtonFor(m => m.AddNote, "No", new { id = "noteNo", onclick = "toggleNotes()" })
                            <label for="noteNo" class="radio-label">
                                <span class="rb-circle"><span class="rb-dot"></span></span>
                                No, thank you
                            </label>
                        </div>
                        <div class="radio-item">
                            @Html.RadioButtonFor(m => m.AddNote, "Yes", new { id = "noteYes", onclick = "toggleNotes()" })
                            <label for="noteYes" class="radio-label">
                                <span class="rb-circle"><span class="rb-dot"></span></span>
                                Yes, I'd like to add a note
                            </label>
                        </div>
                    </div>
                </div>

                <div id="notesPanel" class="notes-panel hidden">
                    <div class="form-group" style="margin-top:20px;">
                        @Html.LabelFor(m => m.Notes, new { @class = "form-label" })
                        @Html.TextAreaFor(m => m.Notes, new { @class = "form-control", rows = 6, placeholder = "" })
                    </div>
                </div>

                <!-- ── SUBMIT ── -->
                <div class="submit-wrap">
                    <div class="submit-note">
                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                        </svg>
                        Your information is secure and will not be shared.
                    </div>
                    <button type="submit" class="btn-submit">
                        <span>Send Request</span>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" />
                        </svg>
                    </button>
                </div>
            }
        </div>

    </div>
</section>

<script>
    function toggleNotes() {
        const panel = document.getElementById('notesPanel');
        const yes = document.getElementById('noteYes');
        if (yes.checked) {
            panel.classList.remove('hidden');
        } else {
            panel.classList.add('hidden');
        }
    }
    document.addEventListener('DOMContentLoaded', toggleNotes);
</script>

@section Scripts {
        @@Scripts.Render("~/bundles/jqueryval")
}
