@{
    ViewData["Title"] = "Home";
}

<style>
    :root {
        --navy-deep: #060F1E;
        --navy-main: #0B1D35;
        --blue-primary: #1A4A8A;
        --blue-soft: #2563B0;
        --blue-glow: #3B82F6;
        --gold-accent: #C9A84C;
        --gold-light: #E8C96A;
        --text-white: #FFFFFF;
        --text-muted: rgba(255,255,255,0.72);
        --text-subtle: rgba(255,255,255,0.42);
        --glass-bg: rgba(11,29,53,0.65);
        --glass-border: rgba(255,255,255,0.09);
    }

    *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        background: var(--navy-deep);
        color: var(--text-white);
        overflow-x: hidden;
        font-family: 'Segoe UI','Helvetica Neue',system-ui,sans-serif;
        -webkit-font-smoothing: antialiased;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(40px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    @@keyframes fadeDown {
        from {
            opacity: 0;
            transform: translateY(-28px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0
        }

        to {
            opacity: 1
        }
    }

    @@keyframes fadeLeft {
        from {
            opacity: 0;
            transform: translateX(-40px)
        }

        to {
            opacity: 1;
            transform: translateX(0)
        }
    }

    @@keyframes fadeRight {
        from {
            opacity: 0;
            transform: translateX(40px)
        }

        to {
            opacity: 1;
            transform: translateX(0)
        }
    }

    @@keyframes shimmerLine {
        0% {
            transform: translateX(-100%)
        }

        100% {
            transform: translateX(200%)
        }
    }

    @@keyframes gradientShift {
        0%, 100% {
            background-position: 0% 50%
        }

        50% {
            background-position: 100% 50%
        }
    }

    @@keyframes dotPulse {
        0%, 100% {
            opacity: 1;
            transform: scale(1)
        }

        50% {
            opacity: .5;
            transform: scale(.7)
        }
    }

    @@keyframes scanLine {
        0% {
            top: -4px
        }

        100% {
            top: 100%
        }
    }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0)
        }

        50% {
            transform: translateY(-10px)
        }
    }

    @@keyframes pulseGlow {
        0%, 100% {
            box-shadow: 0 0 0 0 rgba(59,130,246,0)
        }

        50% {
            box-shadow: 0 0 30px 8px rgba(59,130,246,.12)
        }
    }

    @@keyframes lineGrow {
        from {
            width: 0
        }

        to {
            width: 56px
        }
    }

    @@keyframes counterUp {
        from {
            opacity: 0;
            transform: translateY(16px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    @@keyframes revealUp {
        from {
            opacity: 0;
            transform: translateY(50px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    @@keyframes marquee {
        0% {
            transform: translateX(0)
        }

        100% {
            transform: translateX(-50%)
        }
    }

    /* HERO */
    .hero {
        min-height: 100vh;
        position: relative;
        display: flex;
        align-items: center;
        padding: 130px 7% 110px;
        overflow: hidden;
        isolation: isolate;
    }

    .hero-video-bg {
        position: absolute;
        inset: 0;
        z-index: -3;
        overflow: hidden;
    }

        .hero-video-bg video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: .28;
            filter: brightness(.6) saturate(.7) hue-rotate(195deg);
        }

    .hero-overlay-base {
        position: absolute;
        inset: 0;
        z-index: -2;
        background: linear-gradient(160deg,rgba(6,15,30,.9) 0%,rgba(11,29,53,.74) 45%,rgba(6,15,30,.93) 100%);
    }

    .hero-overlay-radial {
        position: absolute;
        inset: 0;
        z-index: -1;
        background: radial-gradient(ellipse 80% 60% at 60% 40%,rgba(37,99,176,.12) 0%,transparent 70%),radial-gradient(ellipse 50% 40% at 20% 80%,rgba(201,168,76,.06) 0%,transparent 60%);
    }

    .hero-scanline {
        position: absolute;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg,transparent,rgba(59,130,246,.25),transparent);
        z-index: 0;
        animation: scanLine 8s linear infinite;
        pointer-events: none;
    }

    .hero::after {
        content: "";
        position: absolute;
        inset: 0;
        background-image: linear-gradient(rgba(255,255,255,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.025) 1px,transparent 1px);
        background-size: 80px 80px;
        z-index: -1;
        pointer-events: none;
    }

    .hero-container {
        max-width: 1380px;
        margin: 0 auto;
        width: 100%;
        display: grid;
        grid-template-columns: 1.15fr 1fr;
        gap: 72px;
        align-items: center;
        position: relative;
        z-index: 1;
    }

    .hero-content {
        animation: fadeIn 1.4s ease-out;
    }

    .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 7px 20px;
        background: rgba(201,168,76,.08);
        border: 1px solid rgba(201,168,76,.22);
        border-radius: 100px;
        font-size: .7rem;
        font-weight: 700;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--gold-light);
        margin-bottom: 30px;
        animation: fadeDown .9s ease-out .2s backwards;
        position: relative;
        overflow: hidden;
    }

        .hero-eyebrow::after {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 40%;
            height: 100%;
            background: linear-gradient(90deg,transparent,rgba(255,255,255,.12),transparent);
            animation: shimmerLine 3s ease-in-out infinite;
        }

    .eyebrow-dot {
        width: 5px;
        height: 5px;
        background: var(--gold-accent);
        border-radius: 50%;
        animation: dotPulse 2s ease-in-out infinite;
    }

    .hero-content h1 {
        font-size: clamp(2.6rem,5.2vw,4.6rem);
        font-weight: 300;
        line-height: 1.1;
        letter-spacing: -.025em;
        animation: fadeDown .9s ease-out .35s backwards;
    }

    .line-normal {
        display: block;
        color: rgba(255,255,255,.88);
    }

    .line-strong {
        display: block;
        font-weight: 800;
        background: linear-gradient(120deg,#FFFFFF 0%,#A8CBFF 50%,#FFFFFF 100%);
        background-size: 200% 200%;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: fadeDown .9s ease-out .35s backwards,gradientShift 6s ease infinite 1s;
    }

    .hero-divider {
        margin: 26px 0;
        width: 56px;
        height: 2px;
        background: linear-gradient(90deg,var(--gold-accent),transparent);
        animation: lineGrow 1s ease-out .5s backwards;
    }

    .hero-content p {
        font-size: clamp(1rem,1.7vw,1.18rem);
        color: var(--text-muted);
        max-width: 560px;
        line-height: 1.75;
        animation: fadeDown .9s ease-out .55s backwards;
    }

    .hero-actions {
        margin-top: 44px;
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        animation: fadeDown .9s ease-out .7s backwards;
    }

    /* Buttons */
    .btn-primary {
        position: relative;
        background: linear-gradient(135deg,var(--blue-primary),var(--blue-soft));
        color: #fff;
        padding: 15px 38px;
        border-radius: 8px;
        font-weight: 700;
        font-size: .95rem;
        letter-spacing: .03em;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all .3s cubic-bezier(.4,0,.2,1);
        box-shadow: 0 4px 24px rgba(26,74,138,.35),inset 0 1px 0 rgba(255,255,255,.1);
        overflow: hidden;
    }

        .btn-primary::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg,rgba(255,255,255,.12),transparent);
            opacity: 0;
            transition: opacity .3s;
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 40px rgba(26,74,138,.5);
        }

            .btn-primary:hover::before {
                opacity: 1;
            }

    .btn-secondary {
        border: 1.5px solid rgba(255,255,255,.2);
        color: var(--text-white);
        padding: 15px 38px;
        border-radius: 8px;
        font-weight: 600;
        font-size: .95rem;
        letter-spacing: .03em;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all .3s cubic-bezier(.4,0,.2,1);
        backdrop-filter: blur(8px);
        background: rgba(255,255,255,.04);
    }

        .btn-secondary:hover {
            border-color: rgba(255,255,255,.45);
            background: rgba(255,255,255,.08);
            transform: translateY(-3px);
        }

    .btn-outline-gold {
        border: 1.5px solid rgba(201,168,76,.4);
        color: var(--gold-light);
        padding: 13px 32px;
        border-radius: 8px;
        font-weight: 700;
        font-size: .88rem;
        letter-spacing: .05em;
        text-transform: uppercase;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all .3s ease;
        background: rgba(201,168,76,.06);
    }

        .btn-outline-gold:hover {
            background: rgba(201,168,76,.14);
            border-color: rgba(201,168,76,.7);
            color: #fff;
            transform: translateY(-2px);
        }

    /* Hero visual */
    .hero-visual {
        position: relative;
        animation: fadeIn 1.4s ease-out .4s backwards;
    }

    .hero-card {
        background: var(--glass-bg);
        backdrop-filter: blur(24px) saturate(1.4);
        border: 1px solid var(--glass-border);
        border-radius: 20px;
        padding: 24px;
        box-shadow: 0 32px 80px rgba(0,0,0,.5),inset 0 1px 0 rgba(255,255,255,.06);
        transition: all .5s cubic-bezier(.4,0,.2,1);
        animation: pulseGlow 6s ease-in-out infinite;
    }

        .hero-card:hover {
            transform: translateY(-10px);
            border-color: rgba(255,255,255,.18);
            box-shadow: 0 48px 100px rgba(0,0,0,.6),0 0 60px rgba(59,130,246,.1);
        }

    .hero-card-bar {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 18px;
    }

        .hero-card-bar span {
            width: 10px;
            height: 10px;
            border-radius: 50%;
        }

            .hero-card-bar span:nth-child(1) {
                background: #FF5F57
            }

            .hero-card-bar span:nth-child(2) {
                background: #FEBC2E
            }

            .hero-card-bar span:nth-child(3) {
                background: #28C840
            }

    .hero-card img {
        width: 100%;
        border-radius: 12px;
        display: block;
    }

    .floating-stat {
        position: absolute;
        background: rgba(6,15,30,.88);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,.12);
        border-radius: 14px;
        padding: 14px 22px;
        box-shadow: 0 12px 40px rgba(0,0,0,.4);
        animation: float 6s ease-in-out infinite;
    }

    .floating-stat-1 {
        top: 6%;
        left: -10%
    }

    .floating-stat-2 {
        bottom: 10%;
        right: -8%;
        animation-delay: 2.2s
    }

    .floating-stat-3 {
        top: 44%;
        right: -14%;
        animation-delay: 4s
    }

    .fs-label {
        font-size: .65rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--gold-accent);
        margin-bottom: 4px;
        font-weight: 700
    }

    .fs-value {
        font-size: 1.65rem;
        font-weight: 800;
        line-height: 1;
        color: #fff
    }

    .fs-sub {
        font-size: .7rem;
        color: var(--text-subtle);
        margin-top: 3px
    }

    /* Section label */
    .section-label {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: .68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 3px;
        color: var(--gold-accent);
        margin-bottom: 20px;
    }

        .section-label::before {
            content: "";
            width: 24px;
            height: 1px;
            background: var(--gold-accent);
        }

    /* Stats bar */
    .trust-bar {
        padding: 0 7%;
        background: rgba(6,15,30,.92);
        border-top: 1px solid rgba(255,255,255,.06);
        border-bottom: 1px solid rgba(255,255,255,.06);
        backdrop-filter: blur(20px);
    }

    .trust-bar-inner {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(4,1fr);
    }

    .tbi {
        padding: 42px 20px;
        text-align: center;
        position: relative;
        animation: counterUp .8s ease-out backwards;
    }

        .tbi:nth-child(1) {
            animation-delay: .1s
        }

        .tbi:nth-child(2) {
            animation-delay: .2s
        }

        .tbi:nth-child(3) {
            animation-delay: .3s
        }

        .tbi:nth-child(4) {
            animation-delay: .4s
        }

        .tbi + .tbi::before {
            content: "";
            position: absolute;
            left: 0;
            top: 25%;
            bottom: 25%;
            width: 1px;
            background: rgba(255,255,255,.07);
        }

        .tbi h2 {
            font-size: clamp(2.2rem,3.8vw,3.2rem);
            font-weight: 800;
            letter-spacing: -.03em;
            line-height: 1;
            margin-bottom: 8px;
            background: linear-gradient(135deg,#fff 0%,rgba(201,168,76,.9) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .tbi p {
            font-size: .8rem;
            color: var(--text-subtle);
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 600;
        }

    /* About preview */
    .about-preview {
        padding: 120px 7%;
        background: linear-gradient(180deg,var(--navy-deep) 0%,#091829 100%);
        position: relative;
    }

        .about-preview::before {
            content: "";
            position: absolute;
            inset: 0;
            background-image: radial-gradient(rgba(59,130,246,.03) 1px,transparent 1px);
            background-size: 40px 40px;
            pointer-events: none;
        }

    .about-grid {
        max-width: 1280px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: center;
    }

    .about-text {
        animation: fadeLeft .9s ease-out .2s backwards;
    }

        .about-text h2 {
            font-size: clamp(2rem,3.8vw,3rem);
            font-weight: 300;
            letter-spacing: -.025em;
            line-height: 1.2;
            margin-bottom: 20px;
        }

            .about-text h2 strong {
                font-weight: 800;
            }

        .about-text p {
            font-size: clamp(1rem,1.6vw,1.1rem);
            color: var(--text-muted);
            line-height: 1.8;
            margin-bottom: 18px;
        }

            .about-text p:last-of-type {
                margin-bottom: 32px;
            }

    .about-pillars {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
        margin-bottom: 36px;
    }

    .pillar {
        padding: 18px 20px;
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 14px;
        transition: all .3s ease;
        position: relative;
        overflow: hidden;
    }

        .pillar::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg,var(--gold-accent),transparent);
            opacity: 0;
            transition: opacity .3s;
        }

        .pillar:hover {
            border-color: rgba(255,255,255,.15);
            transform: translateY(-4px);
        }

            .pillar:hover::before {
                opacity: 1;
            }

    .pillar-icon {
        font-size: 1.4rem;
        margin-bottom: 8px;
    }

    .pillar-title {
        font-size: .85rem;
        font-weight: 700;
        color: var(--gold-light);
        margin-bottom: 4px;
    }

    .pillar-desc {
        font-size: .8rem;
        color: var(--text-subtle);
        line-height: 1.5;
    }

    .about-visual {
        animation: fadeRight .9s ease-out .35s backwards;
        position: relative;
    }

    .about-img-wrap {
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,.08);
        position: relative;
        transition: all .5s ease;
    }

        .about-img-wrap:hover {
            transform: translateY(-8px);
            border-color: rgba(255,255,255,.15);
            box-shadow: 0 30px 70px rgba(0,0,0,.45);
        }

        .about-img-wrap img {
            width: 100%;
            display: block;
            filter: brightness(.82) saturate(.85);
            transition: filter .5s;
        }

        .about-img-wrap:hover img {
            filter: brightness(.95) saturate(1);
        }

        .about-img-wrap::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 70px;
            height: 70px;
            border-top: 2px solid var(--gold-accent);
            border-left: 2px solid var(--gold-accent);
            border-radius: 20px 0 0 0;
            z-index: 2;
            opacity: .6;
            transition: opacity .3s,width .3s,height .3s;
        }

        .about-img-wrap:hover::before {
            opacity: 1;
            width: 85px;
            height: 85px;
        }

        .about-img-wrap::after {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg,rgba(6,15,30,.45) 0%,transparent 60%);
        }

    .about-badge-float {
        position: absolute;
        bottom: -20px;
        right: -20px;
        background: rgba(6,15,30,.9);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,.12);
        border-radius: 14px;
        padding: 16px 22px;
        z-index: 3;
        box-shadow: 0 12px 40px rgba(0,0,0,.4);
        animation: float 5s ease-in-out infinite;
    }

    .badge-label {
        font-size: .62rem;
        font-weight: 700;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: var(--gold-accent);
        margin-bottom: 5px
    }

    .badge-value {
        font-size: 1.55rem;
        font-weight: 800;
        color: #fff;
        line-height: 1
    }

    .badge-sub {
        font-size: .68rem;
        color: var(--text-subtle);
        margin-top: 3px
    }

    /* Services preview */
    .services-preview {
        padding: 120px 7% 100px;
        background: linear-gradient(180deg,#091829 0%,var(--navy-deep) 100%);
        position: relative;
    }

        .services-preview::before {
            content: "";
            position: absolute;
            inset: 0;
            background-image: radial-gradient(rgba(59,130,246,.032) 1px,transparent 1px);
            background-size: 40px 40px;
            pointer-events: none;
        }

    .sp-header {
        text-align: center;
        max-width: 700px;
        margin: 0 auto 64px;
    }

        .sp-header h2 {
            font-size: clamp(2.2rem,4vw,3.2rem);
            font-weight: 300;
            letter-spacing: -.025em;
            line-height: 1.2;
            margin-bottom: 16px;
        }

            .sp-header h2 strong {
                font-weight: 800;
            }

        .sp-header p {
            font-size: clamp(1rem,1.6vw,1.1rem);
            color: var(--text-muted);
            line-height: 1.75;
        }

    .services-showcase {
        max-width: 1360px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 24px;
        margin-bottom: 52px;
    }

    .svc-card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 20px;
        overflow: hidden;
        position: relative;
        transition: all .45s cubic-bezier(.4,0,.2,1);
        animation: revealUp .7s ease-out backwards;
    }

        .svc-card:nth-child(1) {
            animation-delay: .05s
        }

        .svc-card:nth-child(2) {
            animation-delay: .12s
        }

        .svc-card:nth-child(3) {
            animation-delay: .19s
        }

        .svc-card:nth-child(4) {
            animation-delay: .26s
        }

        .svc-card:nth-child(5) {
            animation-delay: .33s
        }

        .svc-card:nth-child(6) {
            animation-delay: .40s
        }

        .svc-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg,var(--gold-accent),var(--gold-light),var(--gold-accent));
            background-size: 200% 100%;
            opacity: 0;
            transition: opacity .35s;
            z-index: 2;
            animation: shimmerLine 3s linear infinite;
        }

        .svc-card:hover {
            transform: translateY(-10px);
            border-color: rgba(255,255,255,.14);
            box-shadow: 0 28px 70px rgba(0,0,0,.45),0 0 40px rgba(37,99,176,.1);
            background: rgba(11,29,53,.88);
        }

            .svc-card:hover::before {
                opacity: 1;
            }

    .svc-img {
        height: 200px;
        overflow: hidden;
        position: relative;
    }

        .svc-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: brightness(.75) saturate(.85);
            transition: transform .7s ease,filter .5s;
        }

    .svc-card:hover .svc-img img {
        transform: scale(1.07);
        filter: brightness(.9) saturate(1);
    }

    .svc-img::after {
        content: "";
