@{
    ViewData["Title"] = "About Us";
}

<style>
    :root {
        --navy-deep: #060F1E;
        --navy-main: #0B1D35;
        --blue-primary: #1A4A8A;
        --blue-soft: #2563B0;
        --blue-glow: #3B82F6;
        --gold-accent: #C9A84C;
        --gold-light: #E8C96A;
        --text-white: #FFFFFF;
        --text-muted: rgba(255,255,255,0.72);
        --text-subtle: rgba(255,255,255,0.42);
        --glass-bg: rgba(6,15,30,0.55);
        --glass-border: rgba(255,255,255,0.08);
        --glass-border-hover: rgba(255,255,255,0.18);
    }

    *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        background: var(--navy-deep);
        color: var(--text-white);
        overflow-x: hidden;
        font-family: 'Segoe UI', 'Helvetica Neue', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
    }

    /* ===================== ANIMATIONS ===================== */
    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(36px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeDown {
        from {
            opacity: 0;
            transform: translateY(-28px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes fadeLeft {
        from {
            opacity: 0;
            transform: translateX(-40px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes fadeRight {
        from {
            opacity: 0;
            transform: translateX(40px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes shimmerLine {
        0% {
            transform: translateX(-100%);
        }

        100% {
            transform: translateX(200%);
        }
    }

    @@keyframes gradientShift {
        0%, 100% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }
    }

    @@keyframes dotPulse {
        0%, 100% {
            opacity: 1;
            transform: scale(1);
        }

        50% {
            opacity: 0.5;
            transform: scale(0.7);
        }
    }

    @@keyframes scanLine {
        0% {
            top: -4px;
        }

        100% {
            top: 100%;
        }
    }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-12px);
        }
    }

    @@keyframes cardReveal {
        from {
            opacity: 0;
            transform: translateY(44px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes lineGrow {
        from {
            width: 0;
        }

        to {
            width: 56px;
        }
    }

    @@keyframes counterUp {
        from {
            opacity: 0;
            transform: translateY(16px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes pulseRing {
        0% {
            transform: scale(0.95);
            box-shadow: 0 0 0 0 rgba(201,168,76,0.25);
        }

        70% {
            transform: scale(1);
            box-shadow: 0 0 0 14px rgba(201,168,76,0);
        }

        100% {
            transform: scale(0.95);
            box-shadow: 0 0 0 0 rgba(201,168,76,0);
        }
    }

    /* ===================== HERO ===================== */
    .about-hero {
        min-height: 78vh;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 170px 7% 130px;
        overflow: hidden;
        isolation: isolate;
        text-align: center;
    }

    /* Video */
    .hero-video-bg {
        position: absolute;
        inset: 0;
        z-index: -3;
        overflow: hidden;
    }

        .hero-video-bg video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.32;
            filter: brightness(0.55) saturate(0.65) hue-rotate(200deg);
        }

    /* Overlays */
    .hero-overlay-base {
        position: absolute;
        inset: 0;
        z-index: -2;
        background: linear-gradient(160deg, rgba(6,15,30,0.88) 0%, rgba(11,29,53,0.74) 50%, rgba(6,15,30,0.94) 100% );
    }

    .hero-overlay-radial {
        position: absolute;
        inset: 0;
        z-index: -1;
        background: radial-gradient(ellipse 75% 65% at 50% 50%, rgba(37,99,176,0.15) 0%, transparent 70%), radial-gradient(ellipse 40% 30% at 20% 20%, rgba(201,168,76,0.07) 0%, transparent 60%);
    }

    /* Grid overlay */
    .about-hero::after {
        content: "";
        position: absolute;
        inset: 0;
        background-image: linear-gradient(rgba(255,255,255,0.022) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.022) 1px, transparent 1px);
        background-size: 80px 80px;
        z-index: -1;
        pointer-events: none;
    }

    /* Scan line */
    .hero-scanline {
        position: absolute;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg, transparent, rgba(59,130,246,0.22), transparent);
        z-index: 0;
        animation: scanLine 10s linear infinite;
        pointer-events: none;
    }

    .hero-inner {
        position: relative;
        z-index: 1;
        max-width: 860px;
        margin: 0 auto;
        animation: fadeIn 1.3s ease-out;
    }

    /* Eyebrow */
    .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 7px 20px;
        background: rgba(201,168,76,0.08);
        border: 1px solid rgba(201,168,76,0.22);
        border-radius: 100px;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--gold-light);
        margin-bottom: 28px;
        animation: fadeDown 0.9s ease-out 0.2s backwards;
        position: relative;
        overflow: hidden;
    }

        .hero-eyebrow::after {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 40%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.12), transparent);
            animation: shimmerLine 3.5s ease-in-out infinite;
        }

    .eyebrow-dot {
        width: 5px;
        height: 5px;
        background: var(--gold-accent);
        border-radius: 50%;
        animation: dotPulse 2s ease-in-out infinite;
    }

    .about-hero h1 {
        font-size: clamp(2.9rem, 5.8vw, 4.8rem);
        font-weight: 300;
        line-height: 1.1;
        letter-spacing: -0.03em;
        margin-bottom: 26px;
        animation: fadeDown 0.9s ease-out 0.35s backwards;
    }

        .about-hero h1 strong {
            font-weight: 800;
            display: block;
            background: linear-gradient(120deg, #FFFFFF 0%, #A8CBFF 50%, #FFFFFF 100%);
            background-size: 200% 200%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: gradientShift 6s ease infinite 1s;
        }

    .hero-divider {
        width: 56px;
        height: 2px;
        background: linear-gradient(90deg, var(--gold-accent), transparent);
        margin: 26px auto;
        animation: lineGrow 1s ease-out 0.6s backwards;
    }

    .about-hero > .hero-inner p {
        font-size: clamp(1rem, 1.8vw, 1.2rem);
        color: var(--text-muted);
        line-height: 1.8;
        max-width: 720px;
        margin: 0 auto;
        animation: fadeDown 0.9s ease-out 0.55s backwards;
    }

    /* Scroll indicator */
    .hero-scroll {
        position: absolute;
        bottom: 40px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        z-index: 1;
        animation: fadeIn 1.2s ease-out 1.1s backwards;
    }

        .hero-scroll span {
            font-size: 0.62rem;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--text-subtle);
            font-weight: 600;
        }

    .scroll-line {
        width: 1px;
        height: 48px;
        background: linear-gradient(180deg, var(--gold-accent), transparent);
        animation: float 2s ease-in-out infinite;
    }

    /* ===================== SECTION LABEL ===================== */
    .section-label {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 3px;
        color: var(--gold-accent);
        margin-bottom: 20px;
    }

        .section-label::before {
            content: "";
            width: 24px;
            height: 1px;
            background: var(--gold-accent);
        }

    /* ===================== STATS BAR ===================== */
    .stats-bar {
        padding: 0 7%;
        background: rgba(6,15,30,0.92);
        border-top: 1px solid rgba(255,255,255,0.06);
        border-bottom: 1px solid rgba(255,255,255,0.06);
        backdrop-filter: blur(20px);
    }

    .stats-bar-inner {
        max-width: 1100px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
    }

    .stats-bar-item {
        padding: 40px 20px;
        text-align: center;
        position: relative;
        animation: counterUp 0.8s ease-out backwards;
    }

        .stats-bar-item:nth-child(1) {
            animation-delay: 0.1s;
        }

        .stats-bar-item:nth-child(2) {
            animation-delay: 0.2s;
        }

        .stats-bar-item:nth-child(3) {
            animation-delay: 0.3s;
        }

        .stats-bar-item:nth-child(4) {
            animation-delay: 0.4s;
        }

        .stats-bar-item + .stats-bar-item::before {
            content: "";
            position: absolute;
            left: 0;
            top: 25%;
            bottom: 25%;
            width: 1px;
            background: rgba(255,255,255,0.07);
        }

        .stats-bar-item h2 {
            font-size: clamp(2rem, 3.5vw, 2.9rem);
            font-weight: 800;
            letter-spacing: -0.03em;
            line-height: 1;
            margin-bottom: 8px;
            background: linear-gradient(135deg, #fff 0%, rgba(201,168,76,0.9) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .stats-bar-item p {
            font-size: 0.78rem;
            color: var(--text-subtle);
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 600;
        }

    /* ===================== INTRO SECTION ===================== */
    .about-intro {
        padding: 110px 7% 90px;
        position: relative;
        background: linear-gradient(180deg, var(--navy-deep) 0%, #091829 60%, var(--navy-deep) 100%);
    }

        .about-intro::before {
            content: "";
            position: absolute;
            inset: 0;
            background-image: radial-gradient(rgba(59,130,246,0.03) 1px, transparent 1px);
            background-size: 40px 40px;
            pointer-events: none;
        }

    .intro-grid {
        max-width: 1240px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: center;
    }

    .intro-text {
        animation: fadeLeft 0.9s ease-out 0.2s backwards;
    }

        .intro-text h2 {
            font-size: clamp(2rem, 3.8vw, 3rem);
            font-weight: 300;
            line-height: 1.2;
            letter-spacing: -0.025em;
            margin-bottom: 28px;
        }

            .intro-text h2 strong {
                font-weight: 800;
            }

        .intro-text p {
            font-size: clamp(1rem, 1.6vw, 1.1rem);
            color: var(--text-muted);
            line-height: 1.82;
            margin-bottom: 22px;
            padding-left: 20px;
            border-left: 2px solid rgba(201,168,76,0.35);
            transition: border-color 0.3s;
        }

            .intro-text p:hover {
                border-left-color: var(--gold-accent);
            }

            .intro-text p:last-child {
                margin-bottom: 0;
            }

    /* Visual side */
    .intro-visual {
        position: relative;
        animation: fadeRight 0.9s ease-out 0.35s backwards;
    }

    .intro-img-wrap {
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.08);
        position: relative;
        transition: all 0.5s cubic-bezier(0.4,0,0.2,1);
    }

        .intro-img-wrap:hover {
            transform: translateY(-8px);
            border-color: rgba(255,255,255,0.15);
            box-shadow: 0 30px 70px rgba(0,0,0,0.45);
        }

        .intro-img-wrap img {
            width: 100%;
            display: block;
            filter: brightness(0.82) saturate(0.85);
            transition: filter 0.5s, transform 0.6s;
        }

        .intro-img-wrap:hover img {
            filter: brightness(0.95) saturate(1);
            transform: scale(1.04);
        }

        .intro-img-wrap::after {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(6,15,30,0.45) 0%, transparent 60%);
        }
        /* Gold corner */
        .intro-img-wrap::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 70px;
            height: 70px;
            border-top: 2px solid var(--gold-accent);
            border-left: 2px solid var(--gold-accent);
            border-radius: 20px 0 0 0;
            z-index: 2;
            opacity: 0.6;
            transition: opacity 0.3s, width 0.3s, height 0.3s;
        }

        .intro-img-wrap:hover::before {
            opacity: 1;
            width: 85px;
            height: 85px;
        }

    /* Floating badge on image */
    .img-badge {
        position: absolute;
        bottom: -20px;
        right: -20px;
        background: rgba(6,15,30,0.9);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 14px;
        padding: 16px 22px;
        z-index: 3;
        box-shadow: 0 12px 40px rgba(0,0,0,0.4);
        animation: float 5s ease-in-out infinite;
    }

    .img-badge-label {
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: var(--gold-accent);
        margin-bottom: 5px;
    }

    .img-badge-value {
        font-size: 1.6rem;
        font-weight: 800;
        color: #fff;
        line-height: 1;
    }

    .img-badge-sub {
        font-size: 0.7rem;
        color: var(--text-subtle);
        margin-top: 3px;
    }

    /* ===================== CARDS (VISION / OBJECTIVES / VALUES) ===================== */
    .about-cards-section {
        padding: 100px 7% 120px;
        background: linear-gradient(180deg, #091829 0%, var(--navy-deep) 100%);
        position: relative;
    }

        .about-cards-section::before {
            content: "";
            position: absolute;
            inset: 0;
            background-image: radial-gradient(rgba(59,130,246,0.032) 1px, transparent 1px);
            background-size: 40px 40px;
            pointer-events: none;
        }

    .cards-header {
        text-align: center;
        max-width: 680px;
        margin: 0 auto 64px;
    }

        .cards-header h2 {
            font-size: clamp(2.1rem, 3.8vw, 3rem);
            font-weight: 300;
            letter-spacing: -0.025em;
            line-height: 1.2;
            margin-bottom: 16px;
        }

            .cards-header h2 strong {
                font-weight: 800;
            }

        .cards-header p {
            font-size: clamp(1rem, 1.5vw, 1.08rem);
            color: var(--text-muted);
            line-height: 1.75;
        }

    .about-cards {
        max-width: 1280px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 28px;
    }

    /* Card */
    .about-card {
        background: rgba(11,29,53,0.6);
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 20px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        position: relative;
        transition: all 0.5s cubic-bezier(0.4,0,0.2,1);
        animation: cardReveal 0.7s ease-out backwards;
        backdrop-filter: blur(8px);
    }

        .about-card:nth-child(1) {
            animation-delay: 0.05s;
        }

        .about-card:nth-child(2) {
            animation-delay: 0.15s;
        }

        .about-card:nth-child(3) {
            animation-delay: 0.25s;
        }

        /* Gold top bar */
        .about-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--gold-accent), var(--gold-light), var(--gold-accent));
            background-size: 200% 100%;
            opacity: 0;
            transition: opacity 0.4s;
            z-index: 3;
            animation: shimmerLine 3s linear infinite;
        }

        .about-card::after {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 50% 100%, rgba(37,99,176,0.1) 0%, transparent 70%);
            opacity: 0;
            transition: opacity 0.5s;
            pointer-events: none;
            z-index: 0;
        }

        .about-card:hover {
            transform: translateY(-10px);
            border-color: rgba(255,255,255,0.14);
            box-shadow: 0 28px 70px rgba(0,0,0,0.45), 0 0 40px rgba(37,99,176,0.12);
            background: rgba(11,29,53,0.85);
        }

            .about-card:hover::before {
                opacity: 1;
            }

            .about-card:hover::after {
                opacity: 1;
            }

    /* Card image */
    .card-img-wrap {
        position: relative;
        overflow: hidden;
        height: 230px;
        flex-shrink: 0;
    }

        .card-img-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.7s cubic-bezier(0.4,0,0.2,1), filter 0.5s;
            filter: brightness(0.72) saturate(0.8);
        }

    .about-card:hover .card-img-wrap img {
        transform: scale(1.08);
        filter: brightness(0.88) saturate(1);
    }

    .card-img-wrap::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, transparent 30%, rgba(6,15,30,0.82) 100%);
        z-index: 1;
    }
    /* Gold corner accent */
    .card-img-wrap::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 60px;
        height: 60px;
        border-top: 2px solid var(--gold-accent);
        border-left: 2px solid var(--gold-accent);
        border-radius: 20px 0 0 0;
        z-index: 2;
        opacity: 0.5;
        transition: opacity 0.3s, width 0.3s, height 0.3s;
    }

    .about-card:hover .card-img-wrap::before {
        opacity: 1;
        width: 72px;
        height: 72px;
    }

    /* Card icon badge */
    .card-icon {
        position: absolute;
        bottom: 16px;
        right: 20px;
        z-index: 2;
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: rgba(6,15,30,0.85);
        border: 1px solid rgba(201,168,76,0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(10px);
        animation: pulseRing 3s ease-in-out infinite;
    }

        .card-icon svg {
            width: 22px;
            height: 22px;
        }

    /* Card body */
    .card-body {
        padding: 30px 32px 36px;
        flex: 1;
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
    }

    .card-tag {
        font-size: 0.62rem;
        font-weight: 800;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--gold-accent);
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .card-tag::before {
            content: "";
            width: 18px;
            height: 1px;
            background: var(--gold-accent);
        }

    .card-body h3 {
        font-size: clamp(1.2rem, 2vw, 1.45rem);
        font-weight: 700;
        line-height: 1.25;
        letter-spacing: -0.015em;
        margin-bottom: 18px;
        color: #fff;
        transition: color 0.3s;
        position: relative;
        padding-bottom: 16px;
    }

        .card-body h3::after {
            content: "";
            position: absolute;
            bottom: 0;
            left: 0;
            width: 32px;
            height: 1px;
            background: var(--gold-accent);
            transition: width 0.4s ease;
        }

    .about-card:hover .card-body h3 {
        color: var(--gold-light);
    }

        .about-card:hover .card-body h3::after {
            width: 100%;
        }

    .card-body p {
        font-size: 0.97rem;
        color: var(--text-muted);
        line-height: 1.75;
        margin-bottom: 14px;
    }

        .card-body p:last-child {
            margin-bottom: 0;
        }

    /* Values list */
    .card-body ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: 12px;
        flex: 1;
    }

        .card-body ul li {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            font-size: 0.94rem;
            color: var(--text-muted);
            line-height: 1.62;
            transition: color 0.25s, transform 0.25s;
        }

            .card-body ul li:hover {
                color: #fff;
                transform: translateX(4px);
            }

    .li-dot {
        flex-shrink: 0;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: rgba(201,168,76,0.1);
        border: 1px solid rgba(201,168,76,0.35);
        margin-top: 1px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.3s, border-color 0.3s;
    }

        .li-dot svg {
            width: 10px;
            height: 10px;
        }

    .about-card:hover .li-dot {
        background: rgba(201,168,76,0.2);
        border-color: rgba(201,168,76,0.6);
    }

    .li-text strong {
        color: var(--gold-light);
        font-weight: 700;
    }

    /* ===================== VISION QUOTE ===================== */
    .vision-section {
        padding: 120px 7%;
