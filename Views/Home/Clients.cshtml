@{
    ViewData["Title"] = "Clients";
}

<style>
    :root {
        --navy-deep: #060F1E;
        --navy-main: #0B1D35;
        --blue-primary: #1A4A8A;
        --blue-soft: #2563B0;
        --gold-accent: #C9A84C;
        --gold-light: #E8C96A;
        --text-white: #FFFFFF;
        --text-muted: rgba(255,255,255,0.72);
        --text-subtle: rgba(255,255,255,0.42);
    }

    *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        background: var(--navy-deep);
        color: var(--text-white);
        overflow-x: hidden;
        font-family: 'Segoe UI', 'Helvetica Neue', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
    }

    html, body {
        max-width: 100%;
        overflow-x: hidden;
    }
    /* ===================== ANIMATIONS ===================== */
    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(32px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeDown {
        from {
            opacity: 0;
            transform: translateY(-24px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes shimmerLine {
        0% {
            transform: translateX(-100%);
        }

        100% {
            transform: translateX(200%);
        }
    }

    @@keyframes gradientShift {
        0%, 100% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }
    }

    @@keyframes dotPulse {
        0%, 100% {
            opacity: 1;
            transform: scale(1);
        }

        50% {
            opacity: 0.5;
            transform: scale(0.7);
        }
    }

    @@keyframes scanLine {
        0% {
            top: -4px;
        }

        100% {
            top: 100%;
        }
    }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-12px);
        }
    }

    @@keyframes cardReveal {
        from {
            opacity: 0;
            transform: translateY(24px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes counterUp {
        from {
            opacity: 0;
            transform: translateY(16px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes lineGrow {
        from {
            width: 0;
        }

        to {
            width: 56px;
        }
    }

    @@keyframes tickerScroll {
        0% {
            transform: translateX(0);
        }

        100% {
            transform: translateX(-50%);
        }
    }

    /* ===================== HERO ===================== */
    .clients-hero {
        min-height: 72vh;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 170px 7% 130px;
        overflow: hidden;
        isolation: isolate;
        text-align: center;
    }

    .hero-video-bg {
        position: absolute;
        inset: 0;
        z-index: -3;
        overflow: hidden;
    }

        .hero-video-bg video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.22;
            filter: brightness(0.5) saturate(0.6) hue-rotate(200deg);
        }

    .hero-overlay-base {
        position: absolute;
        inset: 0;
        z-index: -2;
        background: linear-gradient(160deg,rgba(6,15,30,0.9) 0%,rgba(11,29,53,0.76) 50%,rgba(6,15,30,0.94) 100%);
    }

    .hero-overlay-radial {
        position: absolute;
        inset: 0;
        z-index: -1;
        background: radial-gradient(ellipse 75% 65% at 50% 50%,rgba(37,99,176,0.14) 0%,transparent 70%), radial-gradient(ellipse 35% 25% at 80% 20%,rgba(201,168,76,0.07) 0%,transparent 60%);
    }

    .clients-hero::after {
        content: "";
        position: absolute;
        inset: 0;
        background-image: linear-gradient(rgba(255,255,255,0.022) 1px,transparent 1px), linear-gradient(90deg,rgba(255,255,255,0.022) 1px,transparent 1px);
        background-size: 80px 80px;
        z-index: -1;
        pointer-events: none;
    }

    .hero-scanline {
        position: absolute;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg,transparent,rgba(59,130,246,0.22),transparent);
        z-index: 0;
        animation: scanLine 10s linear infinite;
        pointer-events: none;
    }

    .hero-inner {
        position: relative;
        z-index: 1;
        max-width: 860px;
        margin: 0 auto;
        animation: fadeIn 1.3s ease-out;
    }

    .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 7px 20px;
        background: rgba(201,168,76,0.08);
        border: 1px solid rgba(201,168,76,0.22);
        border-radius: 100px;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--gold-light);
        margin-bottom: 28px;
        animation: fadeDown 0.9s ease-out 0.2s backwards;
        position: relative;
        overflow: hidden;
    }

        .hero-eyebrow::after {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 40%;
            height: 100%;
            background: linear-gradient(90deg,transparent,rgba(255,255,255,0.12),transparent);
            animation: shimmerLine 3.5s ease-in-out infinite;
        }

    .eyebrow-dot {
        width: 5px;
        height: 5px;
        background: var(--gold-accent);
        border-radius: 50%;
        animation: dotPulse 2s ease-in-out infinite;
    }

    .clients-hero h1 {
        font-size: clamp(2.9rem,5.8vw,4.8rem);
        font-weight: 300;
        line-height: 1.1;
        letter-spacing: -0.03em;
        margin-bottom: 26px;
        animation: fadeDown 0.9s ease-out 0.35s backwards;
    }

        .clients-hero h1 strong {
            font-weight: 800;
            display: block;
            background: linear-gradient(120deg,#FFFFFF 0%,#A8CBFF 50%,#FFFFFF 100%);
            background-size: 200% 200%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: gradientShift 6s ease infinite 1s;
        }

    .hero-divider {
        width: 56px;
        height: 2px;
        background: linear-gradient(90deg,var(--gold-accent),transparent);
        margin: 26px auto;
        animation: lineGrow 1s ease-out 0.6s backwards;
    }

    .clients-hero p {
        font-size: clamp(1rem,1.8vw,1.2rem);
        color: var(--text-muted);
        line-height: 1.8;
        max-width: 700px;
        margin: 0 auto;
        animation: fadeDown 0.9s ease-out 0.55s backwards;
    }

    .hero-scroll {
        position: absolute;
        bottom: 40px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        z-index: 1;
        animation: fadeIn 1.2s ease-out 1.1s backwards;
    }

        .hero-scroll span {
            font-size: 0.62rem;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--text-subtle);
            font-weight: 600;
        }

    .scroll-line {
        width: 1px;
        height: 48px;
        background: linear-gradient(180deg,var(--gold-accent),transparent);
        animation: float 2s ease-in-out infinite;
    }

    /* ===================== SECTION LABEL ===================== */
    .section-label {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 3px;
        color: var(--gold-accent);
        margin-bottom: 20px;
    }

        .section-label::before {
            content: "";
            width: 24px;
            height: 1px;
            background: var(--gold-accent);
        }

    /* ===================== STATS BAR ===================== */
    .stats-bar {
        padding: 0 7%;
        background: rgba(6,15,30,0.92);
        border-top: 1px solid rgba(255,255,255,0.06);
        border-bottom: 1px solid rgba(255,255,255,0.06);
        backdrop-filter: blur(20px);
    }

    .stats-bar-inner {
        max-width: 1100px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(4,1fr);
    }

    .stats-bar-item {
        padding: 40px 20px;
        text-align: center;
        position: relative;
        animation: counterUp 0.8s ease-out backwards;
    }

        .stats-bar-item:nth-child(1) {
            animation-delay: 0.1s;
        }

        .stats-bar-item:nth-child(2) {
            animation-delay: 0.2s;
        }

        .stats-bar-item:nth-child(3) {
            animation-delay: 0.3s;
        }

        .stats-bar-item:nth-child(4) {
            animation-delay: 0.4s;
        }

        .stats-bar-item + .stats-bar-item::before {
            content: "";
            position: absolute;
            left: 0;
            top: 25%;
            bottom: 25%;
            width: 1px;
            background: rgba(255,255,255,0.07);
        }

        .stats-bar-item h2 {
            font-size: clamp(2rem,3.5vw,2.9rem);
            font-weight: 800;
            letter-spacing: -0.03em;
            line-height: 1;
            margin-bottom: 8px;
            background: linear-gradient(135deg,#fff 0%,rgba(201,168,76,0.9) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .stats-bar-item p {
            font-size: 0.78rem;
            color: var(--text-subtle);
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 600;
        }

    /* ===================== TICKER ===================== */
    .ticker-section {
        padding: 48px 0;
        background: rgba(6,15,30,0.7);
        border-bottom: 1px solid rgba(255,255,255,0.05);
        overflow: hidden;
        position: relative;
    }

        .ticker-section::before, .ticker-section::after {
            content: "";
            position: absolute;
            top: 0;
            bottom: 0;
            width: 140px;
            z-index: 2;
            pointer-events: none;
        }

        .ticker-section::before {
            left: 0;
            background: linear-gradient(90deg,rgba(6,15,30,1) 0%,transparent 100%);
        }

        .ticker-section::after {
            right: 0;
            background: linear-gradient(270deg,rgba(6,15,30,1) 0%,transparent 100%);
        }

    .ticker-track {
        display: flex;
        gap: 64px;
        align-items: center;
        width: max-content;
        animation: tickerScroll 40s linear infinite;
    }

        .ticker-track:hover {
            animation-play-state: paused;
        }

    .ticker-logo {
        height: 46px;
        width: auto;
        max-width: 130px;
        object-fit: contain;
        opacity: 0.7;
        transition: opacity 0.3s,transform 0.3s;
        flex-shrink: 0;
        background: white;
        padding: 6px 10px;
        border-radius: 6px;
    }

        .ticker-logo:hover {
            opacity: 1;
            transform: scale(1.1);
        }

    /* ===================== CLIENTS SECTION ===================== */
    .clients-section {
        padding: 110px 7% 100px;
        position: relative;
        background: linear-gradient(180deg,var(--navy-deep) 0%,#091829 60%,var(--navy-deep) 100%);
    }

        .clients-section::before {
            content: "";
            position: absolute;
            inset: 0;
            background-image: radial-gradient(rgba(59,130,246,0.032) 1px,transparent 1px);
            background-size: 40px 40px;
            pointer-events: none;
        }

    .clients-header {
        text-align: center;
        max-width: 700px;
        margin: 0 auto 56px;
    }

        .clients-header h2 {
            font-size: clamp(2.1rem,3.8vw,3rem);
            font-weight: 300;
            letter-spacing: -0.025em;
            line-height: 1.2;
            margin-bottom: 16px;
        }

            .clients-header h2 strong {
                font-weight: 800;
            }

        .clients-header p {
            font-size: clamp(1rem,1.5vw,1.08rem);
            color: var(--text-muted);
            line-height: 1.75;
        }

    /* Filter tabs */
    .sector-tabs {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 52px;
        max-width: 900px;
        margin-left: auto;
        margin-right: auto;
    }

    .sector-tab {
        padding: 9px 24px;
        border-radius: 100px;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        cursor: pointer;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(255,255,255,0.04);
        color: var(--text-muted);
        transition: all 0.25s ease;
        user-select: none;
    }

        .sector-tab:hover, .sector-tab.active {
            background: rgba(201,168,76,0.12);
            border-color: rgba(201,168,76,0.4);
            color: var(--gold-light);
        }

    /* ===================== GRID ===================== */
    .clients-grid {
        max-width: 1380px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 24px;
    }

    /* ===================== CLIENT CARD ===================== */
    .client-card {
        background: rgba(11,29,53,0.7);
        border: 1px solid rgba(255,255,255,0.09);
        border-radius: 18px;
        padding: 28px 22px 24px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 16px;
        position: relative;
        overflow: hidden;
        cursor: pointer;
        transition: all 0.4s cubic-bezier(0.4,0,0.2,1);
        animation: cardReveal 0.6s ease-out backwards;
        backdrop-filter: blur(10px);
    }

        .client-card:nth-child(1) {
            animation-delay: 0.04s;
        }

        .client-card:nth-child(2) {
            animation-delay: 0.08s;
        }

        .client-card:nth-child(3) {
            animation-delay: 0.12s;
        }

        .client-card:nth-child(4) {
            animation-delay: 0.16s;
        }

        .client-card:nth-child(5) {
            animation-delay: 0.20s;
        }

        .client-card:nth-child(6) {
            animation-delay: 0.24s;
        }

        .client-card:nth-child(7) {
            animation-delay: 0.28s;
        }

        .client-card:nth-child(8) {
            animation-delay: 0.32s;
        }

        .client-card:nth-child(9) {
            animation-delay: 0.36s;
        }

        .client-card:nth-child(10) {
            animation-delay: 0.40s;
        }

        .client-card:nth-child(11) {
            animation-delay: 0.44s;
        }

        .client-card:nth-child(12) {
            animation-delay: 0.48s;
        }

        .client-card:nth-child(n+13) {
            animation-delay: 0.52s;
        }

        /* Gold top bar */
        .client-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg,var(--gold-accent),var(--gold-light),var(--gold-accent));
            background-size: 200% 100%;
            opacity: 0;
            transition: opacity 0.35s;
            z-index: 2;
            animation: shimmerLine 3s linear infinite;
        }

        .client-card:hover {
            transform: translateY(-8px);
            border-color: rgba(255,255,255,0.18);
            box-shadow: 0 24px 60px rgba(0,0,0,0.5),0 0 30px rgba(37,99,176,0.12);
            background: rgba(11,29,53,0.95);
        }

            .client-card:hover::before {
                opacity: 1;
            }

    /* ---- LOGO BOX: always white, always visible ---- */
    .client-logo-wrap {
        width: 100%;
        height: 110px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #ffffff;
        border-radius: 12px;
        padding: 16px 20px;
        position: relative;
        z-index: 1;
        flex-shrink: 0;
        transition: box-shadow 0.35s, transform 0.35s;
        box-shadow: 0 2px 12px rgba(0,0,0,0.18);
    }

    .client-card:hover .client-logo-wrap {
        box-shadow: 0 8px 28px rgba(0,0,0,0.3);
        transform: scale(1.03);
    }

    .client-logo {
        max-width: 150px;
        max-height: 75px;
        width: auto;
        height: auto;
        object-fit: contain;
        display: block;
        /* No filter at all — full colour, always visible */
        transition: transform 0.35s;
    }

    .client-card:hover .client-logo {
        transform: scale(1.07);
    }

    /* Name */
    .client-name {
        font-size: 0.88rem;
        font-weight: 600;
        text-align: center;
        color: var(--text-muted);
        letter-spacing: 0.3px;
        line-height: 1.45;
        transition: color 0.3s;
        position: relative;
        z-index: 1;
    }

    .client-card:hover .client-name {
        color: #fff;
    }

    /* Sector badge */
    .client-sector {
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 1.8px;
        text-transform: uppercase;
        padding: 4px 12px;
        border-radius: 100px;
        background: rgba(201,168,76,0.08);
        border: 1px solid rgba(201,168,76,0.2);
        color: rgba(201,168,76,0.65);
        position: relative;
        z-index: 1;
        transition: background 0.3s,color 0.3s,border-color 0.3s;
    }

    .client-card:hover .client-sector {
        background: rgba(201,168,76,0.18);
        border-color: rgba(201,168,76,0.5);
        color: var(--gold-light);
    }

    /* ===================== VISION ===================== */
    .vision-section {
        padding: 120px 7%;
        background: linear-gradient(160deg,#050D1A 0%,#0B1D35 50%,#050D1A 100%);
        border-top: 1px solid rgba(255,255,255,0.05);
        border-bottom: 1px solid rgba(255,255,255,0.05);
        position: relative;
        overflow: hidden;
        text-align: center;
    }

        .vision-section::before {
            content: "";
            position: absolute;
            width: 700px;
            height: 700px;
            border-radius: 50%;
            background: radial-gradient(circle,rgba(59,130,246,0.06) 0%,transparent 70%);
            top: 50%;
            left: 50%;
            transform: translate(-50%,-50%);
            pointer-events: none;
        }

    .vision-quote {
        position: relative;
        max-width: 900px;
        margin: 0 auto;
    }

    .vision-mark {
        font-size: 7rem;
        line-height: 0.6;
        font-family: Georgia,serif;
        color: rgba(201,168,76,0.15);
        display: block;
        margin-bottom: 24px;
        user-select: none;
    }

    .vision-text {
        font-size: clamp(1.45rem,3.2vw,2.3rem);
        font-weight: 300;
        line-height: 1.65;
        letter-spacing: -0.01em;
        color: rgba(255,255,255,0.9);
    }

        .vision-text strong {
            font-weight: 700;
            color: #fff;
        }

    /* ===================== CTA ===================== */
    .cta-section {
        padding: 130px 7%;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .cta-section::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(160deg,rgba(26,74,138,0.9) 0%,rgba(37,99,176,0.85) 50%,rgba(11,29,53,0.95) 100%);
            z-index: -1;
        }

        .cta-section::after {
            content: "";
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(255,255,255,0.03) 1px,transparent 1px), linear-gradient(90deg,rgba(255,255,255,0.03) 1px,transparent 1px);
            background-size: 60px 60px;
            z-index: -1;
        }

        .cta-section h2 {
            font-size: clamp(2.3rem,4.2vw,3.4rem);
            font-weight: 300;
            letter-spacing: -0.025em;
            margin-bottom: 20px;
        }

            .cta-section h2 strong {
                font-weight: 800;
            }

        .cta-section p {
            max-width: 560px;
            margin: 0 auto 48px;
            color: var(--text-muted);
            font-size: clamp(1rem,1.7vw,1.12rem);
            line-height: 1.75;
            animation: fadeUp 0.8s ease-out 0.2s backwards;
        }

    .cta-actions {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
        animation: fadeUp 0.8s ease-out 0.35s backwards;
    }

    .btn-primary {
        position: relative;
        background: linear-gradient(135deg,var(--blue-primary),var(--blue-soft));
        color: #fff;
        padding: 15px 38px;
        border-radius: 8px;
        font-weight: 700;
        font-size: 0.95rem;
        letter-spacing: 0.03em;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
        box-shadow: 0 4px 24px rgba(26,74,138,0.35),inset 0 1px 0 rgba(255,255,255,0.1);
        overflow: hidden;
    }

        .btn-primary::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg,rgba(255,255,255,0.12),transparent);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 40px rgba(26,74,138,0.5);
        }

            .btn-primary:hover::before {
                opacity: 1;
            }

    .btn-secondary {
        border: 1.5px solid rgba(255,255,255,0.2);
        color: var(--text-white);
        padding: 15px 38px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.95rem;
        letter-spacing: 0.03em;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
        backdrop-filter: blur(8px);
        background: rgba(255,255,255,0.04);
    }

        .btn-secondary:hover {
            border-color: rgba(255,255,255,0.45);
            background: rgba(255,255,255,0.08);
            transform: translateY(-3px);
        }

    /* ===================== RESPONSIVE ===================== */
    @@media (max-width:1200px) {
        .clients-grid {
            grid-template-columns: repeat(3,1fr);
        }
    }

