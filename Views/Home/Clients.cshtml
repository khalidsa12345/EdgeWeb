<script>
    function filterClients(sector, el) {
        document.querySelectorAll('.sector-tab').forEach(t => t.classList.remove('active'));
        el.classList.add('active');
        let delay = 0;
        document.querySelectorAll('.client-card').forEach(card => {
            const match = sector === 'all' || card.dataset.sector === sector;
            if (match) {
                card.style.display = 'flex';
                card.style.animationDelay = (delay * 0.05) + 's';
                card.style.animation = 'none';
                void card.offsetWidth;
                card.style.animation = 'cardReveal 0.5s ease-out forwards';
                delay++;
            } else {
                card.style.display = 'none';
            }
        });
    }
</script>
